@model Bonyan.DAL.Models.Inventory
@{
    ViewData["Title"] = "تعديل مخزن";
}
<link rel="stylesheet" href="~/css/employee.css" />
<link rel="stylesheet" href="~/css/material.css" />
<div class="page-header">
    <div class="page-header-left">
        <h2><i class="fas fa-edit" style="color:var(--secondary)"></i> <span data-lang="edit_colon">تعديل:</span> @Model.InventoryName</h2>
        
    </div>
    <a asp-action="Details" asp-route-id="@Model.InventoryID" class="btn-bonyan-primary"><i class="fas fa-arrow-right"></i> <span data-lang="back_to_details">رجوع للتفاصيل</span></a>
</div>
<div class="form-card">
    <div class="form-card-header"><i class="fas fa-warehouse"></i> <h4 data-lang="edit_warehouse_data">تعديل بيانات المخزن</h4></div>
    <div class="form-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="InventoryID" />
            <div class="form-section-title" data-lang="edit_warehouse_data">تعديل بيانات المخزن</div>
            <div class="form-grid-2">
                <div class="form-group">
                    <label><span data-lang="warehouse_name_label">اسم المخزن</span> <span class="required">*</span></label>
                    <input asp-for="InventoryName" class="form-control" required />
                    <span asp-validation-for="InventoryName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label data-lang="location">الموقع</label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label data-lang="storage_capacity">السعة الاستيعابية</label>
                    <input asp-for="Capacity" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>
            </div>
            <div class="form-actions">
                <a asp-action="Details" asp-route-id="@Model.InventoryID" class="btn-bonyan-primary"><i class="fas fa-times"></i> <span data-lang="cancel">إلغاء</span></a>
                <button type="submit" class="btn-bonyan-secondary"><i class="fas fa-save"></i> <span data-lang="save_changes">حفظ التعديلات</span></button>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
