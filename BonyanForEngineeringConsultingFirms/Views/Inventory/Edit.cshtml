@* ── SAVE AS: Views/Inventory/Edit.cshtml ── *@
@model Bonyan.DAL.Models.Inventory
@{
    ViewData["Title"] = "تعديل مخزن";
}

<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-edit" style="color:var(--secondary)"></i>
            تعديل: @Model.InventoryName
        </h2>
    </div>
    <a asp-action="Details" asp-route-id="@Model.InventoryID" class="btn-bonyan-primary">
        <i class="fas fa-arrow-right"></i> رجوع للتفاصيل
    </a>
</div>

<div class="upload-card">
    <div class="upload-card-header">
        <i class="fas fa-warehouse"></i>
        <h4>تعديل بيانات المخزن</h4>
    </div>
    <div class="upload-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="InventoryID" />
            <div class="form-grid-2">
                <div class="form-group">
                    <label>اسم المخزن <span style="color:red">*</span></label>
                    <input asp-for="InventoryName" class="form-control" required />
                    <span asp-validation-for="InventoryName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>الموقع</label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>السعة الاستيعابية</label>
                    <input asp-for="Capacity" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>
            </div>
            <div class="upload-actions">
                <a asp-action="Details" asp-route-id="@Model.InventoryID" class="btn-bonyan-primary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
            </div>
        </form>
    </div>
</div>
