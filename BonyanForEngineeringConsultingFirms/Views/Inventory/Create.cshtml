@* ── SAVE AS: Views/Inventory/Create.cshtml ── *@
@model Bonyan.DAL.Models.Inventory
@{
    ViewData["Title"] = "إضافة مخزن";
}

<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-plus-circle" style="color:var(--secondary)"></i>
            إضافة مخزن جديد
        </h2>
    </div>
    <a asp-action="Index" class="btn-bonyan-primary">
        <i class="fas fa-arrow-right"></i> رجوع للمخازن
    </a>
</div>

<div class="upload-card">
    <div class="upload-card-header">
        <i class="fas fa-warehouse"></i>
        <h4>بيانات المخزن</h4>
    </div>
    <div class="upload-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="form-grid-2">
                <div class="form-group">
                    <label>اسم المخزن <span style="color:red">*</span></label>
                    <input asp-for="InventoryName" class="form-control" placeholder="مثال: مخزن الموقع الرئيسي" required />
                    <span asp-validation-for="InventoryName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>الموقع</label>
                    <input asp-for="Location" class="form-control" placeholder="العنوان التفصيلي للمخزن" />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>السعة الاستيعابية</label>
                    <input asp-for="Capacity" type="number" step="0.01" min="0"
                           class="form-control" placeholder="0.00" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>
            </div>
            <div class="upload-actions">
                <a asp-action="Index" class="btn-bonyan-primary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> حفظ المخزن
                </button>
            </div>
        </form>
    </div>
</div>


