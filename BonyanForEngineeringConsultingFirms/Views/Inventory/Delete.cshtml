@model Bonyan.DAL.Models.Inventory
@{
    ViewData["Title"] = "حذف مخزن";
}
<link rel="stylesheet" href="~/css/employee.css" />
<link rel="stylesheet" href="~/css/employee-dark.css" />

<div class="delete-card">
    <div class="delete-card-header">
        <i class="fas fa-trash-alt"></i>
        <h4 data-lang="delete_warehouse">حذف مخزن</h4>
    </div>
    <div class="delete-card-body">
        <div class="delete-icon">
            <i class="fas fa-warehouse"></i>
        </div>
        <h5 data-lang="delete_confirm">هل أنت متأكد من الحذف؟</h5>
        <p data-lang="delete_warning">لا يمكن التراجع عن هذا الإجراء بعد تأكيده</p>

        <div class="delete-info-box">
            <p>
                <strong data-lang="warehouse_name_label">اسم المخزن: </strong>
                @Model.InventoryName
            </p>
            <p>
                <strong data-lang="location">الموقع: </strong>
                @(Model.Location ?? "—")
            </p>
            <p>
                <strong data-lang="storage_capacity">السعة: </strong>
                @(Model.Capacity.HasValue ? Model.Capacity.Value.ToString("N2") + " م³" : "—")
            </p>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.InventoryID" />
            <a asp-action="Index" class="btn-bonyan-primary">
                <i class="fas fa-times"></i> <span data-lang="cancel">إلغاء</span>
            </a>
            <button type="submit" class="btn-bonyan-danger">
                <i class="fas fa-trash"></i> <span data-lang="delete_confirm_btn">نعم، احذف</span>
            </button>
        </form>
    </div>
</div>
