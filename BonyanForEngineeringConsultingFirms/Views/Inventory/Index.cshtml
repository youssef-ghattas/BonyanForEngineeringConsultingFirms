@* Views/Inventory/Index.cshtml *@
@model IEnumerable<Inventory>
@{
    ViewData["Title"] = "المخازن";
    var role = Context.Session.GetString("Role");
}

<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-warehouse" style="color:var(--secondary)"></i>
            المخازن
        </h2>
    </div>
    @if (role == "Admin")
    {
        <a asp-action="Create" class="btn-bonyan-secondary">
            <i class="fas fa-plus"></i> إضافة مخزن
        </a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success-msg">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error-msg">
        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="details-card">
    @if (Model.Any())
    {
        <table class="mat-table">
            <thead>
                <tr>
                    <th>اسم المخزن</th>
                    <th>الموقع</th>
                    <th>السعة</th>
                    <th>عدد المواد</th>
                    <th>آخر تحديث</th>
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@inv.InventoryID"
                               style="color:var(--primary); font-weight:600; text-decoration:none">
                                <i class="fas fa-warehouse" style="font-size:0.65rem; color:var(--secondary); margin-left:6px"></i>
                                @inv.InventoryName
                            </a>
                        </td>
                        <td>@(inv.Location ?? "—")</td>
                        <td>@(inv.Capacity.HasValue? inv.Capacity.Value.ToString("N0") : "—")</td>
                        <td>
                            <span class="count-badge inv">
                                <i class="fas fa-boxes"></i> @inv.MaterialInventories.Count
                            </span>
                        </td>
                        <td>@inv.LastUpdatedDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@inv.InventoryID"
                               class="btn-action view" title="عرض">
                                <i class="fas fa-eye"></i>
                            </a>
                            @if (role == "Admin")
                            {
                                <a asp-action="Edit" asp-route-id="@inv.InventoryID"
                                   class="btn-action edit" title="تعديل">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@inv.InventoryID" method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('هل أنت متأكد من حذف هذا المخزن؟')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action delete" title="حذف">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-warehouse"></i>
            <p>لا توجد مخازن حتى الآن</p>
        </div>
    }
</div>