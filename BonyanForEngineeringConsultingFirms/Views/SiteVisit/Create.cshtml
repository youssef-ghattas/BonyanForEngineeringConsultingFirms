@model Bonyan.DAL.Models.SiteVisit
@using Bonyan.DAL.Enums
@{
    ViewData["Title"] = "إضافة زيارة موقع";
    int projectId = ViewBag.ProjectId ?? 0;
    string projectName = ViewBag.ProjectName as string ?? "—";
}

<link rel="stylesheet" href="~/css/DocumentAndDrawing.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-hard-hat" style="color:var(--secondary)"></i>
            إضافة زيارة موقع
        </h2>
    </div>
    <a asp-controller="Project" asp-action="Details"
       asp-route-id="@projectId" class="btn-bonyan-primary">
        <i class="fas fa-arrow-right"></i> رجوع للمشروع
    </a>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div style="background:#f8d7da; color:#842029; border-radius:8px;
                    padding:12px 18px; margin-bottom:16px; font-weight:600">
        <i class="fas fa-exclamation-circle"></i>
        يرجى تصحيح الأخطاء أدناه
    </div>
}

<div class="upload-card">
    <div class="upload-card-header">
        <i class="fas fa-map-marker-alt"></i>
        <h4>بيانات زيارة الموقع</h4>
    </div>

    <div class="upload-card-body">
        <div class="project-badge">
            <i class="fas fa-project-diagram"></i>
            @projectName
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProjId" value="@projectId" />

            <div class="form-group">
                <label>تقرير الزيارة <span style="color:red">*</span></label>
                <textarea asp-for="Report" class="form-control" rows="5"
                          placeholder="اكتب تقرير تفصيلي عن الزيارة..." required></textarea>
                <span asp-validation-for="Report" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>حالة السلامة <span style="color:red">*</span></label>
                <select asp-for="SafetyStatus" class="form-select" required>
                    <option value="0">آمن</option>
                    <option value="1">يحتاج انتباه</option>
                    <option value="2">حرج</option>
                </select>
            </div>

            <div class="form-group">
                <label>صورة الموقع (اختياري)</label>
                <input type="file" name="visitPhoto" class="form-control"
                       accept=".jpg,.jpeg,.png,.gif,.webp" />
                <small style="color:#888">الصيغ المسموح بها: jpg, jpeg, png, gif, webp</small>
            </div>

            <div class="upload-actions">
                <a asp-controller="Project" asp-action="Details"
                   asp-route-id="@projectId" class="btn-bonyan-primary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> حفظ الزيارة
                </button>
            </div>
        </form>
    </div>
</div>