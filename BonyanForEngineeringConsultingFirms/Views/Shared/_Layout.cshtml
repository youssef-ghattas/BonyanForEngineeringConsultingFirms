<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bonyan - بنيان</title>

    <!-- Bootstrap RTL -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />

    <!-- Font Awesome Icons -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Google Fonts Arabic + English -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&family=Poppins:wght@400;600;700&display=swap"
          rel="stylesheet" />

    <!-- Our Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- ── Top Navbar ────────────────────────────── -->
    <nav class="bonyan-navbar">
        <!-- Sidebar Toggle Button -->
        <button class="sidebar-toggle" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <!-- Logo -->
        <div class="navbar-logo">
            <i class="fas fa-building"></i>
            <span>Bonyan | بنيان</span>
        </div>

        <!-- Right Side -->
        <div class="navbar-right">
            <!-- Language Switch Button -->
            <button id="langBtn"
                    class="lang-btn"
                    onclick="toggleLanguage()">
                English
            </button>

            <!-- User Info -->
            <div class="navbar-user dropdown">
                <div class="user-info-btn"
                     data-bs-toggle="dropdown"
                     style="cursor:pointer">
                    <i class="fas fa-user-circle fa-lg"></i>
                    <div class="user-details">
                        <span class="user-name">
                            @(Context.Session.GetString("FullName") ?? "المستخدم")
                        </span>
                        <span class="user-role">
                            @(Context.Session.GetString("Role") ?? "")
                        </span>
                    </div>
                    <i class="fas fa-chevron-down fa-xs"></i>
                </div>
                <ul class="dropdown-menu dropdown-menu-end bonyan-dropdown">
                    <li>
                        <span class="dropdown-item-text">
                            <i class="fas fa-user me-2"></i>
                            @(Context.Session.GetString("FullName") ?? "")
                        </span>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item text-danger"
                           asp-controller="Account"
                           asp-action="Logout">
                            <i class="fas fa-sign-out-alt me-2"></i>
                            <span data-lang="logout">تسجيل الخروج</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- ── Wrapper ───────────────────────────────── -->
    <div class="bonyan-wrapper">

        <!-- ── Sidebar ───────────────────────────── -->
        <aside class="bonyan-sidebar" id="sidebar">
            <ul class="sidebar-menu">

                <!-- ── Everyone sees Dashboard ────────────── -->
                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="fas fa-chart-line"></i>
                        <span data-lang="dashboard">لوحة التحكم</span>
                    </a>
                </li>

                @{
                    var role = Context.Session.GetString("Role");
                }

                @if (role == "Admin")
                {
                    <!-- Admin sees everything -->
                    <li class="sidebar-section-title">
                        <span data-lang="management">الإدارة</span>
                    </li>
                    <li>
                        <a asp-controller="Employee" asp-action="Index">
                            <i class="fas fa-users"></i>
                            <span data-lang="employees">الموظفون</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Project" asp-action="Index">
                            <i class="fas fa-project-diagram"></i>
                            <span data-lang="projects">المشاريع</span>
                        </a>
                    </li>
                    <li class="sidebar-section-title">
                        <span data-lang="operations">العمليات</span>
                    </li>
                    <li>
                        <a asp-controller="Task" asp-action="Index">
                            <i class="fas fa-tasks"></i>
                            <span data-lang="tasks">المهام</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Document" asp-action="Index">
                            <i class="fas fa-file-alt"></i>
                            <span data-lang="documents">المستندات</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Drawing" asp-action="Index">
                            <i class="fas fa-drafting-compass"></i>
                            <span data-lang="drawings">الرسومات</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="SiteVisit" asp-action="Index">
                            <i class="fas fa-hard-hat"></i>
                            <span data-lang="sitevisits">زيارات الموقع</span>
                        </a>
                    </li>
                    <li class="sidebar-section-title">
                        <span data-lang="finance">المالية</span>
                    </li>
                    <li>
                        <a asp-controller="Invoice" asp-action="Index">
                            <i class="fas fa-file-invoice-dollar"></i>
                            <span data-lang="invoices">الفواتير</span>
                        </a>
                    </li>
                    <li class="sidebar-section-title">
                        <span data-lang="inventory_section">المخزون</span>
                    </li>
                    <li>
                        <a asp-controller="Material" asp-action="Index">
                            <i class="fas fa-boxes"></i>
                            <span data-lang="materials">المواد</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Supplier" asp-action="Index">
                            <i class="fas fa-truck"></i>
                            <span data-lang="suppliers">الموردون</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Inventory" asp-action="Index">
                            <i class="fas fa-warehouse"></i>
                            <span data-lang="inventory">المخزون</span>
                        </a>
                    </li>
                }

                @if (role == "ProjectManager")
                {
                    <!-- Project Manager sees his projects + task management -->
                    <li class="sidebar-section-title">
                        <span data-lang="my_projects">مشاريعي</span>
                    </li>
                    <li>
                        <a asp-controller="Project" asp-action="Index">
                            <i class="fas fa-project-diagram"></i>
                            <span data-lang="projects">المشاريع</span>
                        </a>
                    </li>
                    <li class="sidebar-section-title">
                        <span data-lang="operations">العمليات</span>
                    </li>
                    <li>
                        <a asp-controller="Task" asp-action="Index">
                            <i class="fas fa-tasks"></i>
                            <span data-lang="tasks">المهام</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Document" asp-action="Index">
                            <i class="fas fa-file-alt"></i>
                            <span data-lang="documents">المستندات</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Drawing" asp-action="Index">
                            <i class="fas fa-drafting-compass"></i>
                            <span data-lang="drawings">الرسومات</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="SiteVisit" asp-action="Index">
                            <i class="fas fa-hard-hat"></i>
                            <span data-lang="sitevisits">زيارات الموقع</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Invoice" asp-action="Index">
                            <i class="fas fa-file-invoice-dollar"></i>
                            <span data-lang="invoices">الفواتير</span>
                        </a>
                    </li>
                }

                @if (role == "Engineer")
                {
                    <!-- Engineer sees his projects + can add everything -->
                    <li class="sidebar-section-title">
                        <span data-lang="my_projects">مشاريعي</span>
                    </li>
                    <li>
                        <a asp-controller="Project" asp-action="Index">
                            <i class="fas fa-project-diagram"></i>
                            <span data-lang="projects">المشاريع</span>
                        </a>
                    </li>
                    <li class="sidebar-section-title">
                        <span data-lang="my_work">عملي</span>
                    </li>
                    <li>
                        <a asp-controller="Task" asp-action="Index">
                            <i class="fas fa-tasks"></i>
                            <span data-lang="tasks">المهام</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Document" asp-action="Index">
                            <i class="fas fa-file-alt"></i>
                            <span data-lang="documents">المستندات</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Drawing" asp-action="Index">
                            <i class="fas fa-drafting-compass"></i>
                            <span data-lang="drawings">الرسومات</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="SiteVisit" asp-action="Index">
                            <i class="fas fa-hard-hat"></i>
                            <span data-lang="sitevisits">زيارات الموقع</span>
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Invoice" asp-action="Index">
                            <i class="fas fa-file-invoice-dollar"></i>
                            <span data-lang="invoices">الفواتير</span>
                        </a>
                    </li>
                }

            </ul>
        </aside>

        <!-- ── Main Content ──────────────────────── -->
        <main class="bonyan-content">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js">
    </script>

    <!-- Language Switch JS -->
    <script src="~/js/lang-switch.js"></script>

    <!-- Sidebar Toggle JS -->
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('collapsed');
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>