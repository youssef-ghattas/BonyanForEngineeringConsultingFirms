@* Views/MaterialInvoice/Create.cshtml *@
@model Bonyan.DAL.Models.MaterialInvoice
@using Bonyan.DAL.Enums
@{
    ViewData["Title"] = "إنشاء فاتورة مادة";
    var materials = ViewBag.Materials as List<Bonyan.DAL.Models.Material> ?? new();
    var suppliers = ViewBag.Suppliers as List<Bonyan.DAL.Models.Supplier> ?? new();
    bool fromMaterial = ViewBag.FromMaterial == true;
}

<link rel="stylesheet" href="~/css/employee.css" />
<link rel="stylesheet" href="~/css/invoice.css" />
<link rel="stylesheet" href="~/css/material.css" />
<link rel="stylesheet" href="~/css/materialinvoice.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-plus-circle" style="color:var(--secondary)"></i>
            <span data-lang="create_material_invoice">إنشاء فاتورة مادة جديدة</span>
        </h2>
    </div>
    @if (!fromMaterial)
    {
        <a asp-action="Index" class="btn-bonyan-primary">
            <i class="fas fa-arrow-right"></i> <span data-lang="back_to_invoices">رجوع للفواتير</span>
        </a>
    }
</div>

@if (fromMaterial)
{
    <div class="locked-fields-banner">
        <i class="fas fa-lock"></i>
        <span>
            <span data-lang="locked_fields_banner">تم تعبئة بيانات المادة والمورد والكمية والسعر تلقائياً ولا يمكن تعديلها. يمكنك إكمال بيانات الضريبة والخصم وتاريخ الاستحقاق وحالة الدفع.</span>
        </span>
    </div>
}

<div class="form-card">
    <div class="form-card-header">
        <i class="fas fa-file-invoice"></i>
        <h4 data-lang="invoice_data">بيانات الفاتورة</h4>
    </div>
    <div class="form-card-body">
        <form asp-action="Create" method="post" id="invForm">
            @Html.AntiForgeryToken()

            <div class="form-section-title" data-lang="invoice_data">بيانات الفاتورة</div>
            <div class="form-grid-2">

                @* ── MATERIAL ── *@
                <div class="form-group">
                    <label data-lang="material">المادة</label> <span style="color:red">*</span>
                    @if (fromMaterial)
                    {
                        var mat = materials.FirstOrDefault(m => m.MaterialID == Model.MaterialID);
                        <input type="hidden" name="MaterialID" value="@Model.MaterialID" />
                        <input type="text"
                               value="@(mat?.MaterialName ?? Model.MaterialID.ToString())"
                               class="form-control input-locked"
                               readonly disabled />
                    }
                    else
                    {
                        <select asp-for="MaterialID" class="form-control" required id="materialSelect">
                            <option value="" data-lang="choose_material_option2">-- اختر المادة --</option>
                            @foreach (var m in materials)
                            {
                                <option value="@m.MaterialID"
                                        data-price="@(m.UnitPrice ?? 0)"
                                        data-unit="@(m.Unit ?? "")"
                                        data-qty="@(m.Quantity ?? 1)">
                                    @m.MaterialName @(!string.IsNullOrEmpty(m.Unit) ? $"({m.Unit})" : "")
                                </option>
                            }
                        </select>
                    }
                    <span asp-validation-for="MaterialID" class="text-danger"></span>
                </div>

                @* ── SUPPLIER ── *@
                <div class="form-group">
                    <label data-lang="supplier">المورد</label> <span style="color:red">*</span>
                    @if (fromMaterial)
                    {
                        var sup = suppliers.FirstOrDefault(s => s.SupplierID == Model.SupplierID);
                        <input type="hidden" name="SupplierID" value="@Model.SupplierID" />
                        <input type="text"
                               value="@(sup?.SupplierName ?? Model.SupplierID.ToString())"
                               class="form-control input-locked"
                               readonly disabled />
                    }
                    else
                    {
                        <select asp-for="SupplierID" class="form-control" required id="supplierSelect">
                            <option value="" data-lang="choose_material_first_option">-- اختر المادة أولاً --</option>
                        </select>
                        <small class="text-muted" id="supplierHint" style="display:none" data-lang="no_suppliers_for_material">
                            لا يوجد موردون مرتبطون بهذه المادة
                        </small>
                    }
                    <span asp-validation-for="SupplierID" class="text-danger"></span>
                </div>

                @* ── QUANTITY ── *@
                <div class="form-group">
                    <label data-lang="quantity">الكمية</label> <span style="color:red">*</span>
                    @if (fromMaterial)
                    {
                        <input type="hidden" name="Quantity" value="@Model.Quantity" />
                        <input type="text"
                               value="@Model.Quantity"
                               class="form-control input-locked"
                               readonly disabled />
                    }
                    else
                    {
                        <input asp-for="Quantity" type="number" step="0.001" min="0.001"
                               class="form-control" required oninput="calcFinal()" />
                    }
                </div>

                @* ── UNIT PRICE ── *@
                <div class="form-group">
                    <label data-lang="unit_price_egp">سعر الوحدة (ج.م)</label> <span style="color:red">*</span>
                    @if (fromMaterial)
                    {
                        <input type="hidden" name="UnitPrice" value="@Model.UnitPrice" />
                        <input type="text"
                               value="@Model.UnitPrice"
                               class="form-control input-locked"
                               readonly disabled />
                    }
                    else
                    {
                        <input asp-for="UnitPrice" type="number" step="0.01" min="0"
                               class="form-control" required oninput="calcFinal()" />
                    }
                </div>

                @* ── TAX ── *@
                <div class="form-group">
                    <label data-lang="tax_percent">نسبة الضريبة (%)</label>
                    <input asp-for="TaxPercent" type="number" step="0.01" min="0" max="100"
                           class="form-control" id="TaxPercent" oninput="calcFinal()" placeholder="0" />
                </div>

                @* ── DISCOUNT ── *@
                <div class="form-group">
                    <label data-lang="discount_percent2">نسبة الخصم (%)</label>
                    <input asp-for="DiscountPercent" type="number" step="0.01" min="0" max="100"
                           class="form-control" id="DiscountPercent" oninput="calcFinal()" placeholder="0" />
                </div>

                @* ── INVOICE DATE ── *@
                <div class="form-group">
                    <label data-lang="invoice_date">تاريخ الفاتورة</label> <span style="color:red">*</span>
                    <input asp-for="InvoiceDate" type="date" class="form-control" required />
                </div>

                @* ── DUE DATE ── *@
                <div class="form-group">
                    <label data-lang="due_date">تاريخ الاستحقاق</label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                </div>

                @* ── STATUS ── *@
                <div class="form-group">
                    <label data-lang="payment_status">حالة الدفع</label>
                    <select asp-for="Status" class="form-control" id="statusSelect" onchange="onStatusChange()">
                        <option value="1" data-lang="invoice_unpaid">غير مدفوعة</option>
                        <option value="0" data-lang="invoice_paid">مدفوعة</option>
                        <option value="2" data-lang="invoice_partial">مدفوعة جزئياً</option>
                    </select>
                </div>

                @* ── AMOUNT PAID (shown only when PartiallyPaid) ── *@
                <div class="form-group" id="amountPaidRow" style="display:none;">
                    <label data-lang="amount_paid">المبلغ المدفوع (ج.م)</label> <span style="color:red">*</span>
                    <input asp-for="AmountPaid" type="number" step="0.01" min="0"
                           class="form-control" id="amountPaidInput"
                           placeholder="0.00" oninput="calcRemaining()" />
                    <span asp-validation-for="AmountPaid" class="text-danger"></span>
                </div>

                @* ── NOTES ── *@
                <div class="form-group" style="grid-column:1 / -1">
                    <label data-lang="notes">ملاحظات</label>
                    <textarea asp-for="Notes" class="form-control" rows="2" data-lang-placeholder="notes_placeholder3" placeholder="أي ملاحظات..."></textarea>
                </div>

            </div>

            @* ── SUMMARY BOX ── *@
            <div class="invoice-summary-box">
                <div class="invoice-summary-title">
                    <i class="fas fa-calculator"></i> <span data-lang="invoice_summary">ملخص الفاتورة</span>
                </div>
                <div class="invoice-summary-grid">
                    <div class="invoice-summary-item">
                        <div class="invoice-summary-label" data-lang="total_before_tax">المجموع قبل الضريبة</div>
                        <div class="invoice-summary-value" id="dispTotal">0.00 ج.م</div>
                    </div>
                    <div class="invoice-summary-item">
                        <div class="invoice-summary-label" data-lang="tax">الضريبة</div>
                        <div class="invoice-summary-value tax-value" id="dispTax">0.00 ج.م</div>
                    </div>
                    <div class="invoice-summary-item">
                        <div class="invoice-summary-label" data-lang="discount">الخصم</div>
                        <div class="invoice-summary-value disc-value" id="dispDisc">0.00 ج.م</div>
                    </div>
                    <div class="invoice-summary-item invoice-summary-final">
                        <div class="invoice-summary-label" data-lang="net_final">الصافي النهائي</div>
                        <div class="invoice-summary-value" id="dispFinal">0.00 ج.م</div>
                    </div>
                    <div class="invoice-summary-item invoice-summary-final" id="rowRemaining" style="display:none;">
                        <div class="invoice-summary-label" style="color:#c62828;" data-lang="remaining_amount">المبلغ المتبقي</div>
                        <div class="invoice-summary-value" id="dispRemaining" style="color:#c62828;">0.00 ج.م</div>
                    </div>
                    <div class="invoice-summary-item" id="rowPaid" style="display:none;">
                        <div class="invoice-summary-label" style="color:#2e7d32;" data-lang="amount_paid">المبلغ المدفوع</div>
                        <div class="invoice-summary-value" id="dispPaid" style="color:#2e7d32;">0.00 ج.م</div>
                    </div>
                </div>
            </div>

            @* ── ACTION BUTTONS ── *@
            <div class="form-actions">
                @if (fromMaterial)
                {
                    <button type="button" class="btn-cancel-invoice" onclick="confirmCancelInvoice()">
                        <i class="fas fa-ban"></i> <span data-lang="cancel_invoice">إلغاء الفاتورة</span>
                    </button>
                }
                else
                {
                    <a asp-action="Index" class="btn-bonyan-primary">
                        <i class="fas fa-times"></i> <span data-lang="cancel">إلغاء</span>
                    </a>
                }

                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> <span data-lang="save_invoice">حفظ الفاتورة</span>
                </button>
            </div>

        </form>

        @if (fromMaterial)
        {
            <form id="cancelInvoiceForm"
                  asp-action="CancelAndDeleteMaterial"
                  asp-controller="MaterialInvoice"
                  method="post"
                  style="display:none">
                @Html.AntiForgeryToken()
                <input type="hidden" name="materialId" value="@Model.MaterialID" />
            </form>
        }
    </div>
</div>

@* ── CANCEL WARNING MODAL ── *@
@if (fromMaterial)
{
    <div id="cancelModal" class="cancel-modal-overlay">
        <div class="cancel-modal-box">
            <div class="cancel-modal-icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h4 class="cancel-modal-title" data-lang="cancel_invoice_warning">تحذير: إلغاء الفاتورة</h4>
            <p class="cancel-modal-body">
                <span data-lang="cancel_invoice_body">سيتم حذف المادة المرتبطة بهذه الفاتورة بشكل نهائي من قاعدة البيانات. هل أنت متأكد من الإلغاء؟</span>
            </p>
            <div class="cancel-modal-actions">
                <button class="btn-modal-back" onclick="closeCancelModal()">
                    <i class="fas fa-arrow-right"></i> <span data-lang="no_go_back">لا، ارجع</span>
                </button>
                <button class="btn-modal-confirm-delete"
                        onclick="document.getElementById('cancelInvoiceForm').submit()">
                    <i class="fas fa-trash"></i> <span data-lang="yes_delete_cancel">نعم، احذف المادة وألغِ الفاتورة</span>
                </button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // ── Supplier loader via AJAX ───────────────────────────────
        var materialSelect = document.getElementById('materialSelect');
        var supplierSelect = document.getElementById('supplierSelect');
        var supplierHint   = document.getElementById('supplierHint');

        if (materialSelect) {
            materialSelect.addEventListener('change', function () {
                var matId = this.value;

                supplierSelect.innerHTML = '<option value="">-- جاري التحميل... --</option>';
                if (supplierHint) supplierHint.style.display = 'none';

                if (!matId) {
                    supplierSelect.innerHTML = '<option value="">-- اختر المادة أولاً --</option>';
                    calcFinal();
                    return;
                }

                fetch('/MaterialInvoice/GetSuppliersForMaterial?materialId=' + matId)
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        supplierSelect.innerHTML = '<option value="">-- اختر المورد --</option>';
                        if (data.length === 0) {
                            if (supplierHint) supplierHint.style.display = 'block';
                        } else {
                            data.forEach(function (s) {
                                var opt = document.createElement('option');
                                opt.value = s.supplierID;
                                opt.textContent = s.supplierName;
                                supplierSelect.appendChild(opt);
                            });
                        }
                    })
                    .catch(function () {
                        supplierSelect.innerHTML = '<option value="">-- خطأ في تحميل الموردين --</option>';
                    });

                // auto-fill unit price and quantity from data attributes
                var selected = materialSelect.options[materialSelect.selectedIndex];
                var price    = selected ? selected.getAttribute('data-price') : null;
                var qty      = selected ? selected.getAttribute('data-qty')   : null;
                var priceEl  = document.querySelector('[name="UnitPrice"]');
                var qtyEl    = document.querySelector('[name="Quantity"]');
                if (priceEl && price) priceEl.value = price;
                if (qtyEl   && qty)   qtyEl.value   = qty;

                calcFinal();
            });
        }

        // ── Calculation ───────────────────────────────────────────
        function calcFinal() {
            var qty      = parseFloat(document.querySelector('[name="Quantity"]')?.value)        || 0;
            var price    = parseFloat(document.querySelector('[name="UnitPrice"]')?.value)       || 0;
            var tax      = parseFloat(document.getElementById('TaxPercent')?.value)     || 0;
            var discount = parseFloat(document.getElementById('DiscountPercent')?.value) || 0;

            var total   = qty * price;
            var taxAmt  = total * tax / 100;
            var discAmt = total * discount / 100;
            var final   = total + taxAmt - discAmt;

            var setEl = function (id, val) {
                var el = document.getElementById(id);
                if (el) el.textContent = val.toFixed(2) + ' ج.م';
            };
            setEl('dispTotal', total);
            setEl('dispTax',   taxAmt);
            setEl('dispDisc',  discAmt);
            setEl('dispFinal', final);

            calcRemaining(); // ← ADD THIS LINE

        }

        document.addEventListener('DOMContentLoaded', calcFinal);

        // ── Cancel modal ──────────────────────────────────────────
        function confirmCancelInvoice() {
            document.getElementById('cancelModal').classList.add('active');
        }
        function closeCancelModal() {
            document.getElementById('cancelModal').classList.remove('active');
        }
                // ── Partial payment logic ─────────────────────────────────────
        function onStatusChange() {
            var status = document.getElementById('statusSelect').value;
            var row    = document.getElementById('amountPaidRow');
            var rowR   = document.getElementById('rowRemaining');
            var rowP   = document.getElementById('rowPaid');

            if (status === '2') {          // PartiallyPaid
                row.style.display  = 'block';
                rowR.style.display = 'flex';
                rowP.style.display = 'flex';
            } else {
                row.style.display  = 'none';
                rowR.style.display = 'none';
                rowP.style.display = 'none';
                document.getElementById('amountPaidInput').value = '';
            }
            calcRemaining();
        }

        function calcRemaining() {
            var finalEl    = document.getElementById('dispFinal');
            var finalText  = finalEl ? finalEl.textContent.replace(' ج.م', '').trim() : '0';
            var final      = parseFloat(finalText) || 0;
            var paid       = parseFloat(document.getElementById('amountPaidInput')?.value) || 0;

            if (paid > final) {
                paid = final;
                document.getElementById('amountPaidInput').value = final.toFixed(2);
            }

            var remaining = final - paid;
            var setEl = function(id, val) {
                var el = document.getElementById(id);
                if (el) el.textContent = val.toFixed(2) + ' ج.م';
            };
            setEl('dispPaid',      paid);
            setEl('dispRemaining', remaining);
        }
    </script>
}
