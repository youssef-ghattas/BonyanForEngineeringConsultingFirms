@* Views/MaterialInvoice/Details.cshtml *@
@model Bonyan.DAL.Models.MaterialInvoice
@using Bonyan.DAL.Enums
@{
    ViewData["Title"] = "تفاصيل فاتورة المادة";
    string statusLabel = Model.Status switch
    {
        InvoiceStatus.Paid => "مدفوعة",
        InvoiceStatus.Unpaid => "غير مدفوعة",
        InvoiceStatus.PartiallyPaid => "مدفوعة جزئياً",
        _ => Model.Status.ToString()
    };
    string statusClass = Model.Status switch
    {
        InvoiceStatus.Paid => "badge-completed",
        InvoiceStatus.Unpaid => "badge-pending",
        InvoiceStatus.PartiallyPaid => "badge-inprogress",
        _ => ""
    };
}

<link rel="stylesheet" href="~/css/employee.css" />
<link rel="stylesheet" href="~/css/invoice.css" />
<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-file-invoice" style="color:var(--secondary)"></i>
            <span data-lang="material_invoice_hash">فاتورة مادة #</span>@Model.MaterialInvoiceID
        </h2>
    </div>
    <div style="display:flex;gap:10px">
        <a asp-action="Index" class="btn-bonyan-primary"><i class="fas fa-arrow-right"></i> <span data-lang="back">رجوع</span></a>
        <a asp-action="Edit" asp-route-id="@Model.MaterialInvoiceID" class="btn-bonyan-secondary">
            <i class="fas fa-edit"></i> <span data-lang="edit">تعديل</span>
        </a>
    </div>
</div>

@await Html.PartialAsync("_AlertMessages")

<!-- Invoice Card -->
<div class="details-card" style="margin-bottom:20px">
    <div class="details-body">
        <div class="details-section">
            <div class="details-section-title"><i class="fas fa-info-circle"></i> <span data-lang="invoice_data">بيانات الفاتورة</span></div>
            <div class="details-grid">
                <div class="detail-item">
                    <label data-lang="material">المادة</label>
                    <p>
                        <a asp-controller="Material" asp-action="Details" asp-route-id="@Model.MaterialID"
                           style="color:var(--primary);font-weight:600;text-decoration:none">
                            @(Model.Material?.MaterialName ?? "—")
                        </a>
                        @if (!string.IsNullOrEmpty(Model.Material?.Unit))
                        {
                            <span class="unit-badge">@Model.Material.Unit</span>
                        }
                    </p>
                </div>
                <div class="detail-item">
                    <label data-lang="supplier">المورد</label>
                    <p>
                        <a asp-controller="Supplier" asp-action="Details" asp-route-id="@Model.SupplierID"
                           style="color:var(--primary);font-weight:600;text-decoration:none">
                            @(Model.Supplier?.SupplierName ?? "—")
                        </a>
                    </p>
                </div>
                <div class="detail-item"><label data-lang="invoice_date">تاريخ الفاتورة</label><p>@Model.InvoiceDate.ToString("yyyy-MM-dd")</p></div>
                <div class="detail-item"><label data-lang="due_date">تاريخ الاستحقاق</label><p>@(Model.DueDate.HasValue? Model.DueDate.Value.ToString("yyyy-MM-dd") : "—")</p></div>
                <div class="detail-item"><label data-lang="status">الحالة</label><p><span class="task-status-badge @statusClass" data-en="@Model.Status.ToString()" data-ar="@statusLabel">@statusLabel</span></p></div>
                <div class="detail-item"><label data-lang="notes">ملاحظات</label><p>@(string.IsNullOrEmpty(Model.Notes) ? "—" : Model.Notes)</p></div>
            </div>
        </div>
    </div>
</div>

<!-- Amount Breakdown -->
<div class="details-card">
    <div class="details-section-title"><i class="fas fa-calculator"></i> <span data-lang="amount_breakdown">تفاصيل المبلغ</span></div>
    <table class="mat-table" style="max-width:600px">
        <tbody>
            <tr>
                <td style="font-weight:600" data-lang="quantity">الكمية</td>
                <td>@Model.Quantity.ToString("N3") @(Model.Material?.Unit ?? "")</td>
            </tr>
            <tr>
                <td style="font-weight:600" data-lang="unit_price">سعر الوحدة</td>
                <td>@Model.UnitPrice.ToString("N2") ج.م</td>
            </tr>
            <tr>
                <td style="font-weight:600" data-lang="mi_total">المجموع</td>
                <td>@Model.TotalAmount.ToString("N2") ج.م</td>
            </tr>
            <tr>
                <td style="font-weight:600"><span data-lang="tax">الضريبة</span> (@(Model.TaxPercent ?? 0)%)</td>
                <td>+@((Model.TotalAmount * (Model.TaxPercent ?? 0) / 100).ToString("N2")) ج.م</td>
            </tr>
            <tr>
                <td style="font-weight:600"><span data-lang="discount">الخصم</span> (@(Model.DiscountPercent ?? 0)%)</td>
                <td style="color:#388e3c">-@((Model.TotalAmount * (Model.DiscountPercent ?? 0) / 100).ToString("N2")) ج.م</td>
            </tr>
            <tr style="background:#e8f5e9">
                <td style="font-weight:700; font-size:1.1rem; color:var(--secondary)" data-lang="net_final">الصافي النهائي</td>
                <td style="font-weight:700; font-size:1.2rem; color:var(--secondary)">@Model.FinalAmount.ToString("N2") ج.م</td>
            </tr>
        </tbody>
    </table>

    <div style="margin-top:16px; display:flex; gap:10px">
        <a asp-action="Edit" asp-route-id="@Model.MaterialInvoiceID" class="btn-bonyan-secondary">
            <i class="fas fa-edit"></i> <span data-lang="edit">تعديل</span>
        </a>
        <form asp-action="Delete" asp-route-id="@Model.MaterialInvoiceID" method="post" style="display:inline"
              onsubmit="return confirm('حذف هذه الفاتورة نهائياً؟')">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-bonyan-primary" style="background:#e53935;border-color:#e53935">
                <i class="fas fa-trash"></i> <span data-lang="delete">حذف</span>
            </button>
        </form>
    </div>
</div>
