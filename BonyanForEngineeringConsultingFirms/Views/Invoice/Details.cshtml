@model Bonyan.DAL.Models.Invoice
@using Bonyan.DAL.Enums
@{
    ViewData["Title"] = "تفاصيل الفاتورة";
    var role = Context.Session.GetString("Role");

    string statusLabel = Model.Invoice_Status switch
    {
        InvoiceStatus.Paid          => "مدفوعة",
        InvoiceStatus.Unpaid        => "غير مدفوعة",
        InvoiceStatus.PartiallyPaid => "مدفوعة جزئياً",
        _ => Model.Invoice_Status.ToString()
    };
    string statusColor = Model.Invoice_Status switch
    {
        InvoiceStatus.Paid          => "#146c43",
        InvoiceStatus.Unpaid        => "#842029",
        InvoiceStatus.PartiallyPaid => "#7c4a00",
        _ => "#666"
    };
    string statusBg = Model.Invoice_Status switch
    {
        InvoiceStatus.Paid          => "#d1e7dd",
        InvoiceStatus.Unpaid        => "#f8d7da",
        InvoiceStatus.PartiallyPaid => "#fff3cd",
        _ => "#eee"
    };

    decimal net = (Model.Total_Amount ?? 0)
                  * (1 + (Model.Tax ?? 0) / 100)
                  * (1 - (Model.Discount ?? 0) / 100);
}
<link rel="stylesheet" href="~/css/employee.css" />
<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-file-invoice-dollar" style="color:var(--secondary)"></i>
            <span data-lang="invoice_hash">فاتورة #</span>@Model.Invoice_ID
        </h2>
    </div>
    <div style="display:flex; gap:10px">
        <a asp-controller="Project" asp-action="Details"
           asp-route-id="@Model.ProjectId" class="btn-bonyan-primary">
            <i class="fas fa-arrow-right"></i> <span data-lang="back_to_project">رجوع للمشروع</span>
        </a>
        @if (role == "Admin")
        {
            <a asp-action="Edit" asp-route-id="@Model.Invoice_ID"
               class="btn-bonyan-secondary">
                <i class="fas fa-edit"></i> <span data-lang="edit">تعديل</span>
            </a>
        }
    </div>
</div>
<div class="details-card">
    <div class="details-body">
        <div class="details-section">
            <div class="details-section-title" data-lang="invoice_data">بيانات الفاتورة</div>
            <div class="details-grid">
                <div class="detail-item">
                    <label data-lang="invoice_number">رقم الفاتورة</label>
                    <p>@Model.Invoice_ID</p>
                </div>
                <div class="detail-item">
                    <label data-lang="project">المشروع</label>
                    <p>@(Model.Project?.ProjectName ?? "—")</p>
                </div>
                <div class="detail-item">
                    <label data-lang="status">الحالة</label>
                    <p><span class="invoice-status-badge"
                          style="display:inline-block; padding:2px 10px; border-radius:12px; background:@statusBg; color:@statusColor"
                          data-en="@Model.Invoice_Status.ToString()" data-ar="@statusLabel">@statusLabel</span></p>
                </div>
                <div class="detail-item">
                    <label data-lang="issue_date">تاريخ الإصدار</label>
                    <p>@Model.Invoice_Date.ToString("yyyy-MM-dd")</p>
                </div>
                <div class="detail-item">
                    <label data-lang="due_date">تاريخ الاستحقاق</label>
                    <p>@(Model.Due_Date.HasValue ? Model.Due_Date.Value.ToString("yyyy-MM-dd") : "—")</p>
                </div>
            </div>
        </div>
        <div class="details-section">
            <div class="details-section-title" data-lang="amount_details">تفاصيل المبلغ</div>
            <div class="details-grid">
                <div class="detail-item">
                    <label data-lang="base_amount">المبلغ الأساسي</label>
                    <p>@((Model.Total_Amount ?? 0).ToString("N2")) <span data-lang="currency_egp">ج.م</span></p>
                </div>
                <div class="detail-item">
                    <label data-lang="tax">الضريبة (@((Model.Tax ?? 0).ToString("N1"))%)</label>
                    <p>+@(((Model.Total_Amount ?? 0) * (Model.Tax ?? 0) / 100).ToString("N2")) <span data-lang="currency_egp">ج.م</span></p>
                </div>
                <div class="detail-item">
                    <label data-lang="discount">الخصم (@((Model.Discount ?? 0).ToString("N1"))%)</label>
                    <p>-@(((Model.Total_Amount ?? 0) * (Model.Discount ?? 0) / 100).ToString("N2")) <span data-lang="currency_egp">ج.م</span></p>
                </div>
                <div class="detail-item">
                    <label data-lang="final_total">الإجمالي النهائي</label>
                    <p><strong>@net.ToString("N2") <span data-lang="currency_egp">ج.م</span></strong></p>
                </div>
            </div>
        </div>
        @if (Model.Payments != null && Model.Payments.Any())
        {
            <div class="details-section">
                <div class="details-section-title">
                    <i class="fas fa-money-bill-wave"></i> <span data-lang="payments">المدفوعات</span>
                </div>
                <table class="doc-table">
                    <thead>
                        <tr>
                            <th data-lang="amount">المبلغ</th>
                            <th data-lang="payment_method">طريقة الدفع</th>
                            <th data-lang="status">الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Payments)
                        {
                            string pmtMethodLabel = p.PaymentMethod switch
                            {
                                Bonyan.DAL.Enums.PaymentMethod.Cash => "نقدي",
                                Bonyan.DAL.Enums.PaymentMethod.CreditCard => "بطاقة ائتمان",
                                Bonyan.DAL.Enums.PaymentMethod.BankTransfer => "تحويل بنكي",
                                _ => p.PaymentMethod.ToString()
                            };
                            string pmtStatusLabel = p.Payment_Status switch
                            {
                                Bonyan.DAL.Enums.PaymentStatus.Completed => "مكتمل",
                                Bonyan.DAL.Enums.PaymentStatus.Pending => "معلق",
                                Bonyan.DAL.Enums.PaymentStatus.Failed => "فشل",
                                _ => p.Payment_Status.ToString()
                            };
                            <tr>
                                <td>@p.PaymentAmount.ToString("N2") <span data-lang="currency_egp">ج.م</span></td>
                                <td>
                                    <span data-en="@p.PaymentMethod.ToString()" data-ar="@pmtMethodLabel">@pmtMethodLabel</span>
                                </td>
                                <td>
                                    <span data-en="@p.Payment_Status.ToString()" data-ar="@pmtStatusLabel">@pmtStatusLabel</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        @if (role == "Admin")
        {
            <div style="margin-top:24px; padding-top:16px; border-top:1px solid #eee">
                <form asp-action="Delete" asp-route-id="@Model.Invoice_ID" method="post"
                      style="display:inline"
                      onsubmit="return confirm('Are you sure you want to delete this invoice?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-bonyan-danger">
                        <i class="fas fa-trash"></i> <span data-lang="delete_invoice">حذف الفاتورة</span>
                    </button>
                </form>
            </div>
        }
    </div>
</div>
