@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>بُنيَان | Bonyan - About</title>

    <script>
        (function () {
            const savedLang = localStorage.getItem("lang") || "ar";
            document.documentElement.setAttribute("lang", savedLang);
            document.documentElement.setAttribute("dir", savedLang === "ar" ? "rtl" : "ltr");
        })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css?v=1.0" />
    <link rel="stylesheet" href="~/css/landing.css?v=1.0" />
    <link rel="stylesheet" href="~/css/about.css?v=1.0" />
    <link rel="stylesheet" href="~/css/navbar.css" />
    <link rel="stylesheet" href="~/css/theme-pro.css" />
</head>
<body class="about-body">
    <script>
        (function () {
            var saved = localStorage.getItem('bonyan-dark');
            var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            var on = saved === '1' || (saved === null && prefersDark);
            if (on) document.body.classList.add('dark-mode');
        })();
    </script>

    <!-- ═══ NAVBAR ═══ -->
    <nav class="bonyan-navbar">
        <div class="navbar-left">
            <a href="@Url.Action("Landing", "Home")" class="navbar-logo">
                <span class="navbar-logo-mark"><i class="fas fa-building"></i></span>
                <span data-lang="logo_text" class="navbar-logo-text">بُنيَان</span>
            </a>
        </div>

        <div class="navbar-main-links d-none d-md-flex">
            <a href="@Url.Action("Index", "Home")" class="navbar-nav-link">
                <i class="fas fa-home"></i>
                <span data-lang="home">الرئيسية</span>
            </a>
            <a href="@Url.Action("About", "Home")" class="navbar-nav-link active">
                <i class="fas fa-circle-info"></i>
                <span data-lang="about">من نحن</span>
            </a>
        </div>

        <div class="navbar-right">
            <button class="navbar-icon-btn" id="darkModeBtn" onclick="toggleDarkMode()" title="Dark / Light" aria-label="Toggle theme">
                <i class="fas fa-moon" id="darkModeIcon"></i>
            </button>
            <button id="langBtn" class="lang-btn" onclick="toggleLanguage()">
                <i class="fas fa-globe me-1"></i>
                <span id="langBtnText">English</span>
            </button>
        </div>
    </nav>

    <!-- ═══ HERO ═══ -->
    <section class="about-hero">
        <div class="about-hero-bg-shapes">
            <div class="shape shape-1"></div>
            <div class="shape shape-2"></div>
            <div class="shape shape-3"></div>
        </div>
        <div class="about-hero-content">
            <div class="about-hero-badge">
                <i class="fas fa-building"></i>
                <span data-lang="about">من نحن</span>
            </div>
            <h1 class="about-hero-title" data-lang="about_title">نبني اليوم هندسة الغد</h1>
            <p class="about-hero-subtitle" data-lang="about_subtitle">منصة رقمية متكاملة تمكّن المكاتب الهندسية من إدارة مشاريعها بكفاءة واحترافية</p>
            <div class="about-hero-features">
                <div class="hero-feature">
                    <i class="fas fa-tasks"></i>
                    <span data-lang="about_hf_tasks">إدارة المهام</span>
                </div>
                <div class="hero-feature">
                    <i class="fas fa-file-invoice"></i>
                    <span data-lang="about_hf_invoices">الفواتير</span>
                </div>
                <div class="hero-feature">
                    <i class="fas fa-hard-hat"></i>
                    <span data-lang="about_hf_sitevisits">زيارات المواقع</span>
                </div>
                <div class="hero-feature">
                    <i class="fas fa-boxes"></i>
                    <span data-lang="about_hf_inventory">المخزون</span>
                </div>
                <div class="hero-feature">
                    <i class="fas fa-file-alt"></i>
                    <span data-lang="about_hf_documents">المستندات</span>
                </div>
                <div class="hero-feature">
                    <i class="fas fa-chart-pie"></i>
                    <span data-lang="about_hf_reports">التقارير</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ MISSION & VISION ═══ -->
    <section class="about-section">
        <div class="about-container">
            <div class="about-mv-grid">
                <div class="mv-card mv-card--mission">
                    <div class="mv-icon">
                        <i class="fas fa-bullseye"></i>
                    </div>
                    <h3 data-lang="about_mission_title">رسالتنا</h3>
                    <p data-lang="about_mission_text">تمكين المكاتب الهندسية من التحول الرقمي الكامل من خلال أدوات ذكية ومتكاملة تسهّل إدارة المشاريع، وتُحسّن الإنتاجية، وتُعزّز الشفافية بين الفرق والعملاء.</p>
                </div>
                <div class="mv-card mv-card--vision">
                    <div class="mv-icon">
                        <i class="fas fa-eye"></i>
                    </div>
                    <h3 data-lang="about_vision_title">رؤيتنا</h3>
                    <p data-lang="about_vision_text">أن نكون المنصة الأولى عربياً في إدارة المكاتب الهندسية، ونُحدث نقلة نوعية في طريقة تصميم وتنفيذ المشاريع الهندسية عبر التكنولوجيا.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ STORY ═══ -->
    <section class="about-section about-section--alt">
        <div class="about-container">
            <div class="about-story">
                <div class="about-story-content">
                    <h2 data-lang="about_story_title">قصتنا</h2>
                    <p data-lang="about_story_text1">انطلقت منصة بُنيَان من رؤية واضحة: سد الفجوة الرقمية في قطاع المكاتب الهندسية. وُلدت الفكرة من تحديات حقيقية يواجهها المهندسون يومياً — من إدارة المهام والمشاريع إلى تتبع المستندات والفواتير وزيارات المواقع.</p>
                    <p data-lang="about_story_text2">اليوم، بُنيَان هي شريك رقمي موثوق للمكاتب الهندسية، تقدم حلولاً متكاملة تجمع بين القوة والمرونة والبساطة، لتساعد الفرق على التركيز على ما يجيدونه: بناء المستقبل.</p>
                </div>
                <div class="about-story-visual">
                    <div class="story-icon-grid">
                        <div class="story-icon-item"><i class="fas fa-hard-hat"></i></div>
                        <div class="story-icon-item"><i class="fas fa-drafting-compass"></i></div>
                        <div class="story-icon-item"><i class="fas fa-chart-line"></i></div>
                        <div class="story-icon-item"><i class="fas fa-handshake"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ VALUES ═══ -->
    <section class="about-section">
        <div class="about-container">
            <div class="about-section-header">
                <h2 data-lang="about_values_title">قيمنا</h2>
                <p data-lang="about_values_subtitle">المبادئ التي توجه كل خطوة نخطوها</p>
            </div>
            <div class="about-values-grid">
                <div class="value-card">
                    <div class="value-icon"><i class="fas fa-star"></i></div>
                    <h4 data-lang="about_val1_title">الجودة</h4>
                    <p data-lang="about_val1_text">نسعى لأعلى معايير الجودة في كل ما نقدمه، من واجهات المستخدم إلى تجربة العميل.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon"><i class="fas fa-lightbulb"></i></div>
                    <h4 data-lang="about_val2_title">الابتكار</h4>
                    <p data-lang="about_val2_text">نتبنى أحدث التقنيات والحلول الإبداعية لمواكبة تطور المجال الهندسي.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon"><i class="fas fa-hand-holding-heart"></i></div>
                    <h4 data-lang="about_val3_title">الثقة</h4>
                    <p data-lang="about_val3_text">نبني علاقات طويلة المدى قائمة على الشفافية والموثوقية مع عملائنا.</p>
                </div>
                <div class="value-card">
                    <div class="value-icon"><i class="fas fa-users"></i></div>
                    <h4 data-lang="about_val4_title">التعاون</h4>
                    <p data-lang="about_val4_text">نؤمن بقوة العمل الجماعي ونسهل التعاون بين الفرق والعملاء بسلاسة.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ ACHIEVEMENTS ═══ -->
    <section class="about-section about-section--alt">
        <div class="about-container">
            <div class="about-section-header">
                <h2 data-lang="about_achievements_title">إنجازاتنا</h2>
                <p data-lang="about_achievements_subtitle">محطات رئيسية في مسيرة بُنيَان نحو التميز الرقمي</p>
            </div>
            <div class="about-milestones">
                <div class="milestone-card">
                    <div class="milestone-year">2026</div>
                    <div class="milestone-content">
                        <h4 data-lang="about_ms1_title">انطلاق المنصة</h4>
                        <p data-lang="about_ms1_text">إطلاق النسخة الأولى من بُنيَان مع أول ١٠ مكاتب هندسية كشركاء مؤسسين.</p>
                    </div>
                </div>
                <div class="milestone-card">
                    <div class="milestone-year">2026</div>
                    <div class="milestone-content">
                        <h4 data-lang="about_ms2_title">أكثر من ٥٠٠ مستخدم</h4>
                        <p data-lang="about_ms2_text">تجاوز عدد المهندسين المسجلين ٥٠٠ مستخدم عبر ٣٥ مكتباً هندسياً في مصر.</p>
                    </div>
                </div>
                <div class="milestone-card">
                    <div class="milestone-year">2027</div>
                    <div class="milestone-content">
                        <h4 data-lang="about_ms3_title">إدارة أكثر من ١٠٠٠ مشروع</h4>
                        <p data-lang="about_ms3_text">إدارة أكثر من ١٠٠٠ مشروع هندسي بنجاح عبر المنصة بمعدل رضا يتجاوز ٩٥٪.</p>
                    </div>
                </div>
                <div class="milestone-card">
                    <div class="milestone-year">2027</div>
                    <div class="milestone-content">
                        <h4 data-lang="about_ms4_title">التوسع الإقليمي</h4>
                        <p data-lang="about_ms4_text">افتتاح مكاتب تمثيل في المملكة العربية السعودية والإمارات العربية المتحدة.</p>
                    </div>
                </div>
                <div class="milestone-card">
                    <div class="milestone-year">2028</div>
                    <div class="milestone-content">
                        <h4 data-lang="about_ms5_title">شراكات استراتيجية</h4>
                        <p data-lang="about_ms5_text">عقد شراكات مع كبرى شركات المقاولات والمطورين العقاريين في المنطقة.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section class="about-cta">
        <div class="about-container">
            <h2 data-lang="about_cta_title">هل أنت مستعد للانطلاق مع بُنيَان؟</h2>
            <p data-lang="about_cta_text">انضم إلى مئات المكاتب الهندسية التي تثق ببُنيَان لإدارة مشاريعها</p>

        </div>
    </section>

    <!-- ═══ FOOTER ═══ -->
    <footer class="about-footer">
        <div class="about-container">
            <div class="about-footer-grid">
                <div>
                    <div class="about-footer-logo">
                        <i class="fas fa-building"></i>
                        <span data-lang="logo_text">بُنيَان</span>
                    </div>
                    <p data-lang="about_footer_text">المنصة الرقمية المتكاملة لإدارة المكاتب الهندسية.</p>
                </div>
                <div>
                    <h5 data-lang="about_footer_links">روابط سريعة</h5>
                    <ul>
                        <li><a href="@Url.Action("Index", "Home")" data-lang="home">الرئيسية</a></li>
                        <li><a href="@Url.Action("About", "Home")" data-lang="about">من نحن</a></li>
                    </ul>
                </div>

            </div>
            <div class="about-footer-bottom">
                <p>&copy; @DateTime.Now.Year Bonyan. <span data-lang="about_footer_rights">جميع الحقوق محفوظة.</span></p>
            </div>
        </div>
    </footer>

    <script src="~/js/translations.js"></script>
    <script src="~/js/lang-switch.js"></script>
    <script src="~/js/about.js"></script>
    <script>
        (function () {
            var darkBtn  = document.getElementById('darkModeBtn');
            var darkIcon = document.getElementById('darkModeIcon');

            function applyDarkMode(on) {
                document.body.classList.toggle('dark-mode', on);
                darkIcon.className = on ? 'fas fa-sun' : 'fas fa-moon';
                localStorage.setItem('bonyan-dark', on ? '1' : '0');
            }

            window.toggleDarkMode = function () {
                applyDarkMode(!document.body.classList.contains('dark-mode'));
            };

            darkIcon.className = document.body.classList.contains('dark-mode') ? 'fas fa-sun' : 'fas fa-moon';
        })();
    </script>
</body>
</html>
