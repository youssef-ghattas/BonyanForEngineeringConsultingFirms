                function toggleTheme() {
            const body = document.body;
            const icon = document.getElementById('themeIcon');
            const isDark = body.classList.toggle('dark-mode');

            icon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';

            // Persist preference across page refreshes
            localStorage.setItem('bonyan-theme', isDark ? 'dark' : 'light');
        }

        // Apply saved theme on page load
        (function () {
            const saved = localStorage.getItem('bonyan-theme');
            if (saved === 'dark') {
                document.body.classList.add('dark-mode');
                const icon = document.getElementById('themeIcon');
                if (icon) icon.className = 'fas fa-sun';
            }
        })();
        function toggleLanding() {
            const html = document.documentElement;
            const isAr = html.lang === "ar";
            const newLang = isAr ? "en" : "ar";

            html.lang = newLang;
            html.dir = newLang === "ar" ? "rtl" : "ltr";
            document.getElementById("langBtn").textContent = newLang === "ar" ? "English" : "العربية";

            document.querySelectorAll("[data-lang]").forEach(el => {
                const key = el.getAttribute("data-lang");
                if (landingTranslations[newLang][key]) {
                    el.textContent = landingTranslations[newLang][key];
                }
            });
        }
