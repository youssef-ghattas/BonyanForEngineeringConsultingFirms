@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>بنيان | Bonyan - منصة إدارة المكاتب الهندسية</title>

    <!-- Bootstrap RTL -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />

    <!-- Font Awesome Icons -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Google Fonts Arabic + English -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Poppins:wght@400;600;700&display=swap"
          rel="stylesheet" />

    <!-- Our Existing Tokens / Components -->
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />

    <!-- Landing Page Specific Styles -->
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body class="landing-body">

    <!-- ── Landing Navbar ─────────────────────────── -->
    <nav class="landing-navbar">
        <div class="navbar-logo landing-logo">
            <i class="fas fa-building"></i>
            <span>Bonyan</span>
        </div>

        <div class="navbar-right">
            <button id="langBtn" class="lang-btn" onclick="toggleLanding()">English</button>
            <a class="btn-bonyan-primary" asp-controller="Account" asp-action="Login">
                <i class="fas fa-sign-in-alt"></i>
                <span data-lang="nav_login">تسجيل الدخول</span>
            </a>
        </div>
    </nav>

    <!-- ── Hero Section ───────────────────────────── -->
    <section class="hero-section">
        <div class="hero-grid">

            <!-- Left Column -->
            <div class="hero-text">
                <span class="hero-badge">
                    <i class="fas fa-bolt"></i>
                    <span data-lang="hero_badge">مميزات المنصة</span>
                </span>

                <h1 class="hero-title">
                    <span data-lang="hero_title_1">مستقبل</span>
                    <span class="text-gold" data-lang="hero_title_2">إدارة المكاتب الهندسية</span>
                </h1>

                <p class="hero-subtitle" data-lang="hero_subtitle">
                    منصة رقمية متكاملة تُحدث نقلة في طريقة إدارة المكاتب الهندسية لمشاريعها ومخططاتها وعملائها وعقودها ومهامها وفرقها — كل ذلك من لوحة تحكم واحدة قوية.
                </p>

                <a class="btn-bonyan-primary hero-cta-btn" asp-controller="Account" asp-action="Login">
                    <span data-lang="hero_cta">تسجيل دخول ←</span>
                </a>
            </div>

            <!-- Right Column: Dashboard Preview Mockup -->
            <div class="hero-mockup">
                <div class="mockup-floating-badge">
                    <i class="fas fa-sack-dollar"></i>
                    <span data-lang="mockup_badge">إجمالي الميزانية 5.2 مليون $</span>
                </div>

                <div class="bonyan-card mockup-card">
                    <div class="mockup-stats-grid">
                        <div class="stat-card stat-card-mini">
                            <div class="stat-icon blue"><i class="fas fa-diagram-project"></i></div>
                            <div class="stat-info">
                                <h3>24</h3>
                                <p data-lang="stat_projects_label">مشروع نشط</p>
                            </div>
                        </div>
                        <div class="stat-card stat-card-mini">
                            <div class="stat-icon green"><i class="fas fa-list-check"></i></div>
                            <div class="stat-info">
                                <h3>128</h3>
                                <p data-lang="stat_tasks_label">مهمة منجزة</p>
                            </div>
                        </div>
                        <div class="stat-card stat-card-mini">
                            <div class="stat-icon gold"><i class="fas fa-handshake"></i></div>
                            <div class="stat-info">
                                <h3>18</h3>
                                <p data-lang="stat_clients_label">عميل</p>
                            </div>
                        </div>
                        <div class="stat-card stat-card-mini">
                            <div class="stat-icon red"><i class="fas fa-file-alt"></i></div>
                            <div class="stat-info">
                                <h3>342</h3>
                                <p data-lang="stat_documents_label">مستند</p>
                            </div>
                        </div>
                    </div>

                    <div class="mockup-chart">
                        <div class="chart-bar-row">
                            <span class="chart-bar-label" data-lang="chart_planning">تخطيط</span>
                            <div class="progress-bar-wrap">
                                <div class="progress-bar-fill" style="width:30%; background:#1565C0;"></div>
                            </div>
                        </div>
                        <div class="chart-bar-row">
                            <span class="chart-bar-label" data-lang="chart_inprogress">قيد التنفيذ</span>
                            <div class="progress-bar-wrap">
                                <div class="progress-bar-fill" style="width:55%; background:#C8922A;"></div>
                            </div>
                        </div>
                        <div class="chart-bar-row">
                            <span class="chart-bar-label" data-lang="chart_completed">مكتمل</span>
                            <div class="progress-bar-wrap">
                                <div class="progress-bar-fill" style="width:80%; background:#28A745;"></div>
                            </div>
                        </div>
                        <div class="chart-bar-row">
                            <span class="chart-bar-label" data-lang="chart_onhold">متوقف</span>
                            <div class="progress-bar-wrap">
                                <div class="progress-bar-fill" style="width:15%; background:#6A1B9A;"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- ── Features Grid Section ─────────────────── -->
    <section class="features-section">
        <div class="section-header">
            <h2 data-lang="features_title">كل ما يحتاجه مكتبك الهندسي</h2>
            <p data-lang="features_subtitle">مجموعة متكاملة من الأدوات لإدارة مكتبك الهندسي بكفاءة وسهولة</p>
        </div>

        <div class="features-grid">
            <div class="bonyan-card feature-card">
                <div class="stat-icon blue"><i class="fas fa-diagram-project"></i></div>
                <h3 data-lang="feat1_title">إدارة المشاريع</h3>
                <p data-lang="feat1_desc">تتبع كل مشروع منذ البداية وحتى التسليم. راقب الحالة والميزانيات والجداول الزمنية والمعالم الرئيسية لحظة بلحظة.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon gold"><i class="fas fa-list-check"></i></div>
                <h3 data-lang="feat2_title">إسناد المهام</h3>
                <p data-lang="feat2_desc">أسند المهام للمهندسين، حدد المواعيد النهائية، وتابع التقدم والمهام المتأخرة بتنبيهات تلقائية.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon green"><i class="fas fa-folder-open"></i></div>
                <h3 data-lang="feat3_title">إدارة المستندات</h3>
                <p data-lang="feat3_desc">ارفع ونظّم وحمّل المخططات والرسومات والمستندات المرتبطة مباشرة بكل مشروع.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon red"><i class="fas fa-handshake"></i></div>
                <h3 data-lang="feat4_title">إدارة العملاء والعقود</h3>
                <p data-lang="feat4_desc">احتفظ بسجلات كاملة للعملاء والعقود والميزانيات. اربط العملاء مباشرة بمشاريعهم.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon purple"><i class="fas fa-users-gear"></i></div>
                <h3 data-lang="feat5_title">الموارد البشرية</h3>
                <p data-lang="feat5_desc">أدر فريق المهندسين والأدوار وصلاحيات الوصول. أضف أعضاء جدد ببيانات دخول تُنشأ تلقائياً.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon teal"><i class="fas fa-language"></i></div>
                <h3 data-lang="feat6_title">ثنائي اللغة (عربي/إنجليزي)</h3>
                <p data-lang="feat6_desc">دعم كامل للغة العربية (RTL) والإنجليزية (LTR) مع تبديل فوري للغة عبر المنصة بالكامل.</p>
            </div>
        </div>
    </section>

    <!-- ── Bottom CTA Banner ──────────────────────── -->
    <section class="cta-banner">
        <h2 data-lang="cta_title">هل أنت مستعد لتطوير مكتبك الهندسي؟</h2>
        <p data-lang="cta_subtitle">سجّل الدخول للوصول إلى مساحة العمل المتكاملة لإدارة مكتبك الهندسي.</p>
        <a class="btn-bonyan-secondary cta-btn" asp-controller="Account" asp-action="Login">
            <span data-lang="cta_button">تسجيل دخول ←</span>
        </a>
    </section>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Landing Language Switch -->
    <script>
        const landingTranslations = {
            ar: {
                nav_login: "تسجيل الدخول",
                hero_badge: "مميزات المنصة",
                hero_title_1: "مستقبل",
                hero_title_2: "إدارة المكاتب الهندسية",
                hero_subtitle: "منصة رقمية متكاملة تُحدث نقلة في طريقة إدارة المكاتب الهندسية لمشاريعها ومخططاتها وعملائها وعقودها ومهامها وفرقها — كل ذلك من لوحة تحكم واحدة قوية.",
                hero_cta: "تسجيل دخول ←",
                mockup_badge: "إجمالي الميزانية 5.2 مليون $",
                stat_projects_label: "مشروع نشط",
                stat_tasks_label: "مهمة منجزة",
                stat_clients_label: "عميل",
                stat_documents_label: "مستند",
                chart_planning: "تخطيط",
                chart_inprogress: "قيد التنفيذ",
                chart_completed: "مكتمل",
                chart_onhold: "متوقف",
                features_title: "كل ما يحتاجه مكتبك الهندسي",
                features_subtitle: "مجموعة متكاملة من الأدوات لإدارة مكتبك الهندسي بكفاءة وسهولة",
                feat1_title: "إدارة المشاريع",
                feat1_desc: "تتبع كل مشروع منذ البداية وحتى التسليم. راقب الحالة والميزانيات والجداول الزمنية والمعالم الرئيسية لحظة بلحظة.",
                feat2_title: "إسناد المهام",
                feat2_desc: "أسند المهام للمهندسين، حدد المواعيد النهائية، وتابع التقدم والمهام المتأخرة بتنبيهات تلقائية.",
                feat3_title: "إدارة المستندات",
                feat3_desc: "ارفع ونظّم وحمّل المخططات والرسومات والمستندات المرتبطة مباشرة بكل مشروع.",
                feat4_title: "إدارة العملاء والعقود",
                feat4_desc: "احتفظ بسجلات كاملة للعملاء والعقود والميزانيات. اربط العملاء مباشرة بمشاريعهم.",
                feat5_title: "الموارد البشرية",
                feat5_desc: "أدر فريق المهندسين والأدوار وصلاحيات الوصول. أضف أعضاء جدد ببيانات دخول تُنشأ تلقائياً.",
                feat6_title: "ثنائي اللغة (عربي/إنجليزي)",
                feat6_desc: "دعم كامل للغة العربية (RTL) والإنجليزية (LTR) مع تبديل فوري للغة عبر المنصة بالكامل.",
                cta_title: "هل أنت مستعد لتطوير مكتبك الهندسي؟",
                cta_subtitle: "سجّل الدخول للوصول إلى مساحة العمل المتكاملة لإدارة مكتبك الهندسي.",
                cta_button: " تسجيل دخول←"
            },
            en: {
                nav_login: "Login",
                hero_badge: "Platform Features",
                hero_title_1: "The Future of",
                hero_title_2: "Engineering Office Management",
                hero_subtitle: "An integrated digital platform that transforms how engineering offices manage projects, blueprints, clients, contracts, tasks, and teams — all from one powerful dashboard.",
                hero_cta: "Login →",
                mockup_badge: "TOTAL BUDGET $5.2M",
                stat_projects_label: "Active Projects",
                stat_tasks_label: "Completed Tasks",
                stat_clients_label: "Clients",
                stat_documents_label: "Documents",
                chart_planning: "Planning",
                chart_inprogress: "In Progress",
                chart_completed: "Completed",
                chart_onhold: "On Hold",
                features_title: "Everything Your Engineering Office Needs",
                features_subtitle: "A complete suite of tools to manage every aspect of your engineering office efficiently.",
                feat1_title: "Project Management",
                feat1_desc: "Track every project from inception to delivery. Monitor status, budgets, timelines, and milestones in real-time.",
                feat2_title: "Task Assignment",
                feat2_desc: "Assign tasks to engineers, set deadlines, track progress and overdue items with automatic alerts.",
                feat3_title: "Document Control",
                feat3_desc: "Upload, organize, and download blueprints, drawings, and documents linked directly to each project.",
                feat4_title: "Client & Contract Management",
                feat4_desc: "Maintain complete client records, contracts, and budgets. Link clients directly to their projects.",
                feat5_title: "Human Resources",
                feat5_desc: "Manage engineering staff, roles, and access. Onboard new team members with auto-generated credentials.",
                feat6_title: "Bilingual (AR / EN)",
                feat6_desc: "Full Arabic RTL and English LTR support with one-click language switching across the entire platform.",
                cta_title: "Ready to Transform Your Engineering Office?",
                cta_subtitle: "Log in to access your complete engineering management workspace.",
                cta_button: "Login →"
            }
        };

        function toggleLanding() {
            const html = document.documentElement;
            const isAr = html.lang === "ar";
            const newLang = isAr ? "en" : "ar";

            html.lang = newLang;
            html.dir = newLang === "ar" ? "rtl" : "ltr";
            document.getElementById("langBtn").textContent = newLang === "ar" ? "English" : "العربية";

            document.querySelectorAll("[data-lang]").forEach(el => {
                const key = el.getAttribute("data-lang");
                if (landingTranslations[newLang][key]) {
                    el.textContent = landingTranslations[newLang][key];
                }
            });
        }
    </script>
</body>
</html>