@model BonyanForEngineeringConsultingFirms.ViewModels.LandingStatsViewModel
@{
    Layout = null;

    // Safe helpers so view never crashes if model is null (e.g. during design-time)
    int offices = Model?.TotalSubscribedOffices ?? 0;
    int completed = Model?.TotalCompletedProjects ?? 0;
    int total = Model?.TotalProjects ?? 0;
    int docs = Model?.TotalDocuments ?? 0;
    double planPct = Model?.PlanningPercent ?? 30;
    double progPct = Model?.InProgressPercent ?? 55;
    double compPct = Model?.CompletedPercent ?? 80;
    double holdPct = Model?.OnHoldPercent ?? 15;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>بنيان | Bonyan - منصة إدارة المكاتب الهندسية</title>

    <!-- Bootstrap RTL -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />

    <!-- Font Awesome Icons -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Google Fonts Arabic + English -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Poppins:wght@400;600;700&display=swap"
          rel="stylesheet" />

    <!-- Our Existing Tokens / Components -->
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />

    <!-- Landing Page Specific Styles -->
    <link rel="stylesheet" href="~/css/landing.css" />
</head>
<body class="landing-body">

    <!-- ── Landing Navbar ─────────────────────────── -->
    <nav class="landing-navbar">
        <div class="navbar-logo landing-logo">
            <i class="fas fa-building"></i>
            <span>Bonyan</span>
        </div>

        <div class="navbar-right">
            <button id="langBtn" class="lang-btn" onclick="toggleLanding()">English</button>

            <!-- Dark / Light Toggle -->
            <button id="themeToggleBtn" class="theme-toggle-btn" onclick="toggleTheme()" title="تبديل الوضع">
                <i class="fas fa-moon" id="themeIcon"></i>
            </button>

            <!-- Subscription CTA -->
            <a class="btn-bonyan-secondary nav-subscribe-btn" href="#pricing">
                <i class="fas fa-credit-card"></i>
                <span data-lang="nav_subscribe">الاشتراك</span>
            </a>

            <a class="btn-bonyan-primary" asp-controller="Account" asp-action="Login">
                <i class="fas fa-sign-in-alt"></i>
                <span data-lang="nav_login">تسجيل الدخول</span>
            </a>
        </div>
    </nav>

    <!-- ── Hero Section ───────────────────────────── -->
    <section class="hero-section">
        <div class="hero-grid">

            <!-- Left Column -->
            <div class="hero-text">
                <span class="hero-badge">
                    <i class="fas fa-bolt"></i>
                    <span data-lang="hero_badge">مميزات المنصة</span>
                </span>

                <h1 class="hero-title">
                    <span data-lang="hero_title_1">مستقبل</span>
                    <span class="text-gold" data-lang="hero_title_2">إدارة المكاتب الهندسية</span>
                </h1>

                <p class="hero-subtitle" data-lang="hero_subtitle">
                    منصة رقمية متكاملة تُحدث نقلة في طريقة إدارة المكاتب الهندسية لمشاريعها ومخططاتها وعملائها وعقودها ومهامها وفرقها — كل ذلك من لوحة تحكم واحدة قوية.
                </p>

                <a class="btn-bonyan-primary hero-cta-btn" asp-controller="Account" asp-action="Login">
                    <span data-lang="hero_cta">تسجيل دخول ←</span>
                </a>
            </div>

            <div class="bonyan-card mockup-card" style="padding: 18px;">

               
                <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:18px;">

                   
                    <div style="padding:14px 14px 12px; border-radius:8px; border:0.5px solid rgba(0,0,0,0.08); background:#f8f9fc; display:flex; flex-direction:column; gap:10px;">
                        <div style="display:flex; align-items:center; justify-content:space-between;">
                            <div style="width:34px;height:34px;border-radius:8px;background:#E6F1FB;color:#185FA5;display:flex;align-items:center;justify-content:center;font-size:16px;">
                                <i class="fas fa-building-columns"></i>
                            </div>
                            <span style="font-size:9px;font-weight:600;padding:2px 7px;border-radius:99px;background:#E6F1FB;color:#185FA5;letter-spacing:.04em;">OFFICES</span>
                        </div>
                        <span style="font-size:26px;font-weight:600;color:#1a1a2e;line-height:1;">+@offices</span>
                        <div style="border-top:0.5px solid rgba(0,0,0,0.08);padding-top:8px;display:flex;flex-direction:column;gap:2px;">
                            <span style="font-size:11px;color:#1a1a2e;font-weight:600;" data-lang="stat_offices_label">مكتب هندسي مشترك</span>
                            <span style="font-size:10px;color:#888;line-height:1.4;">Subscribed engineering offices across the platform</span>
                        </div>
                    </div>

                    
                    <div style="padding:14px 14px 12px; border-radius:8px; border:0.5px solid rgba(0,0,0,0.08); background:#f8f9fc; display:flex; flex-direction:column; gap:10px;">
                        <div style="display:flex; align-items:center; justify-content:space-between;">
                            <div style="width:34px;height:34px;border-radius:8px;background:#EAF3DE;color:#3B6D11;display:flex;align-items:center;justify-content:center;font-size:16px;">
                                <i class="fas fa-circle-check"></i>
                            </div>
                            <span style="font-size:9px;font-weight:600;padding:2px 7px;border-radius:99px;background:#EAF3DE;color:#3B6D11;letter-spacing:.04em;">DELIVERED</span>
                        </div>
                        <span style="font-size:26px;font-weight:600;color:#1a1a2e;line-height:1;">@completed</span>
                        <div style="border-top:0.5px solid rgba(0,0,0,0.08);padding-top:8px;display:flex;flex-direction:column;gap:2px;">
                            <span style="font-size:11px;color:#1a1a2e;font-weight:600;" data-lang="stat_completed_label">مشروع مُسلَّم بنجاح</span>
                            <span style="font-size:10px;color:#888;line-height:1.4;">Projects completed and handed over to clients</span>
                        </div>
                    </div>

                    
                    <div style="padding:14px 14px 12px; border-radius:8px; border:0.5px solid rgba(0,0,0,0.08); background:#f8f9fc; display:flex; flex-direction:column; gap:10px;">
                        <div style="display:flex; align-items:center; justify-content:space-between;">
                            <div style="width:34px;height:34px;border-radius:8px;background:#FAEEDA;color:#854F0B;display:flex;align-items:center;justify-content:center;font-size:16px;">
                                <i class="fas fa-table-cells-large"></i>
                            </div>
                            <span style="font-size:9px;font-weight:600;padding:2px 7px;border-radius:99px;background:#FAEEDA;color:#854F0B;letter-spacing:.04em;">PROJECTS</span>
                        </div>
                        <span style="font-size:26px;font-weight:600;color:#1a1a2e;line-height:1;">@total</span>
                        <div style="border-top:0.5px solid rgba(0,0,0,0.08);padding-top:8px;display:flex;flex-direction:column;gap:2px;">
                            <span style="font-size:11px;color:#1a1a2e;font-weight:600;" data-lang="stat_projects_label">إجمالي المشاريع المسجّلة</span>
                            <span style="font-size:10px;color:#888;line-height:1.4;">All projects registered system-wide</span>
                        </div>
                    </div>

                   
                    <div style="padding:14px 14px 12px; border-radius:8px; border:0.5px solid rgba(0,0,0,0.08); background:#f8f9fc; display:flex; flex-direction:column; gap:10px;">
                        <div style="display:flex; align-items:center; justify-content:space-between;">
                            <div style="width:34px;height:34px;border-radius:8px;background:#FCEBEB;color:#A32D2D;display:flex;align-items:center;justify-content:center;font-size:16px;">
                                <i class="fas fa-file-lines"></i>
                            </div>
                            <span style="font-size:9px;font-weight:600;padding:2px 7px;border-radius:99px;background:#FCEBEB;color:#A32D2D;letter-spacing:.04em;">DOCUMENTS</span>
                        </div>
                        <span style="font-size:26px;font-weight:600;color:#1a1a2e;line-height:1;">@docs.ToString("N0")</span>
                        <div style="border-top:0.5px solid rgba(0,0,0,0.08);padding-top:8px;display:flex;flex-direction:column;gap:2px;">
                            <span style="font-size:11px;color:#1a1a2e;font-weight:600;" data-lang="stat_documents_label">مستند ومخطط هندسي</span>
                            <span style="font-size:10px;color:#888;line-height:1.4;">Technical docs &amp; drawings uploaded</span>
                        </div>
                    </div>

                </div>

               
                <div style="height:0.5px;background:rgba(0,0,0,0.08);margin:0 0 14px;"></div>

                
                <div style="display:flex;flex-direction:column;gap:9px;">

                    <div style="display:grid;grid-template-columns:110px 1fr 34px;align-items:center;gap:10px;">
                        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#666;">
                            <span style="width:7px;height:7px;border-radius:50%;background:#1565C0;flex-shrink:0;"></span>
                            <span data-lang="chart_planning">تخطيط · Planning</span>
                        </span>
                        <div style="height:5px;background:#eee;border-radius:99px;overflow:hidden;">
                            <div style="height:100%;width:@(planPct)%;background:#1565C0;border-radius:99px;"></div>
                        </div>
                        <span style="font-size:10px;color:#999;text-align:right;font-weight:500;">@(planPct)%</span>
                    </div>

                    <div style="display:grid;grid-template-columns:110px 1fr 34px;align-items:center;gap:10px;">
                        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#666;">
                            <span style="width:7px;height:7px;border-radius:50%;background:#C8922A;flex-shrink:0;"></span>
                            <span data-lang="chart_inprogress">قيد التنفيذ · Active</span>
                        </span>
                        <div style="height:5px;background:#eee;border-radius:99px;overflow:hidden;">
                            <div style="height:100%;width:@(progPct)%;background:#C8922A;border-radius:99px;"></div>
                        </div>
                        <span style="font-size:10px;color:#999;text-align:right;font-weight:500;">@(progPct)%</span>
                    </div>

                    <div style="display:grid;grid-template-columns:110px 1fr 34px;align-items:center;gap:10px;">
                        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#666;">
                            <span style="width:7px;height:7px;border-radius:50%;background:#28A745;flex-shrink:0;"></span>
                            <span data-lang="chart_completed">مكتمل · Delivered</span>
                        </span>
                        <div style="height:5px;background:#eee;border-radius:99px;overflow:hidden;">
                            <div style="height:100%;width:@(compPct)%;background:#28A745;border-radius:99px;"></div>
                        </div>
                        <span style="font-size:10px;color:#999;text-align:right;font-weight:500;">@(compPct)%</span>
                    </div>

                    <div style="display:grid;grid-template-columns:110px 1fr 34px;align-items:center;gap:10px;">
                        <span style="display:flex;align-items:center;gap:5px;font-size:11px;color:#666;">
                            <span style="width:7px;height:7px;border-radius:50%;background:#A32D2D;flex-shrink:0;"></span>
                            <span data-lang="chart_onhold">متوقف · On Hold</span>
                        </span>
                        <div style="height:5px;background:#eee;border-radius:99px;overflow:hidden;">
                            <div style="height:100%;width:@(holdPct)%;background:#A32D2D;border-radius:99px;"></div>
                        </div>
                        <span style="font-size:10px;color:#999;text-align:right;font-weight:500;">@(holdPct)%</span>
                    </div>

                </div>
            </div>
    </section>

    <!-- ── Features Grid Section ─────────────────── -->
    <section class="features-section">
        <div class="section-header">
            <h2 data-lang="features_title">كل ما يحتاجه مكتبك الهندسي</h2>
            <p data-lang="features_subtitle">مجموعة متكاملة من الأدوات لإدارة مكتبك الهندسي بكفاءة وسهولة</p>
        </div>

        <div class="features-grid">
            <div class="bonyan-card feature-card">
                <div class="stat-icon blue"><i class="fas fa-diagram-project"></i></div>
                <h3 data-lang="feat1_title">إدارة المشاريع</h3>
                <p data-lang="feat1_desc">تتبع كل مشروع منذ البداية وحتى التسليم. راقب الحالة والميزانيات والجداول الزمنية والمعالم الرئيسية لحظة بلحظة.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon gold"><i class="fas fa-list-check"></i></div>
                <h3 data-lang="feat2_title">إسناد المهام</h3>
                <p data-lang="feat2_desc">أسند المهام للمهندسين، حدد المواعيد النهائية، وتابع التقدم والمهام المتأخرة بتنبيهات تلقائية.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon green"><i class="fas fa-folder-open"></i></div>
                <h3 data-lang="feat3_title">إدارة المستندات</h3>
                <p data-lang="feat3_desc">ارفع ونظّم وحمّل المخططات والرسومات والمستندات المرتبطة مباشرة بكل مشروع.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon red"><i class="fas fa-handshake"></i></div>
                <h3 data-lang="feat4_title">إدارة العملاء والعقود</h3>
                <p data-lang="feat4_desc">احتفظ بسجلات كاملة للعملاء والعقود والميزانيات. اربط العملاء مباشرة بمشاريعهم.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon purple"><i class="fas fa-users-gear"></i></div>
                <h3 data-lang="feat5_title">الموارد البشرية</h3>
                <p data-lang="feat5_desc">أدر فريق المهندسين والأدوار وصلاحيات الوصول. أضف أعضاء جدد ببيانات دخول تُنشأ تلقائياً.</p>
            </div>

            <div class="bonyan-card feature-card">
                <div class="stat-icon teal"><i class="fas fa-language"></i></div>
                <h3 data-lang="feat6_title">ثنائي اللغة (عربي/إنجليزي)</h3>
                <p data-lang="feat6_desc">دعم كامل للغة العربية (RTL) والإنجليزية (LTR) مع تبديل فوري للغة عبر المنصة بالكامل.</p>
            </div>
        </div>
    </section>


    <!-- ── Pricing Section ────────────────────────────── -->
    <section class="pricing-section" id="pricing">
        <div class="section-header">
            <span class="hero-badge" style="margin-bottom:16px;">
                <i class="fas fa-layer-group"></i>
                <span data-lang="pricing_badge">خطط الأسعار</span>
            </span>
            <h2 data-lang="pricing_title">اختر الخطة المناسبة لمكتبك</h2>
            <p data-lang="pricing_subtitle">جميع الخطط تتضمن كافة مميزات المنصة كاملةً — الفرق الوحيد هو حجم الاستخدام المسموح.</p>
        </div>

        <div class="pricing-grid">

            <!-- ── Startup Plan ── -->
            <div class="pricing-card">
                <div class="pricing-card-header">
                    <div class="pricing-plan-icon blue">
                        <i class="fas fa-seedling"></i>
                    </div>
                    <div>
                        <h3 class="pricing-plan-name" data-lang="plan1_name">Startup</h3>
                        <p class="pricing-plan-name-ar" data-lang="plan1_name_ar">الباقة الناشئة</p>
                    </div>
                </div>

                <div class="pricing-price-block">
                    <span class="pricing-price" data-lang="plan1_price">٤,٠٠٠</span>
                    <span class="pricing-currency" data-lang="plan1_currency">ج.م / شهرياً</span>
                </div>

                <div class="pricing-limits">
                    <div class="pricing-limit-item">
                        <i class="fas fa-users"></i>
                        <div>
                            <span class="limit-number">20</span>
                            <span class="limit-label" data-lang="limit_engineers">مهندس</span>
                        </div>
                    </div>
                    <div class="pricing-limit-divider"></div>
                    <div class="pricing-limit-item">
                        <i class="fas fa-folder-open"></i>
                        <div>
                            <span class="limit-number">5</span>
                            <span class="limit-label" data-lang="limit_projects">مشاريع نشطة</span>
                        </div>
                    </div>
                </div>

                <p class="pricing-desc" data-lang="plan1_desc">
                    كافة مميزات المنصة القوية، مهيأة للمكاتب الناشئة وفرق العمل الصغيرة لتنظيم مشاريعها الرقمية الأولى.
                </p>

                <ul class="pricing-features-list">
                    <li><i class="fas fa-check"></i> <span data-lang="feat_kanban">لوحة إدارة وتكليف المهام</span></li>
                    <li><i class="fas fa-check"></i> <span data-lang="feat_archive">الأرشيف السحابي الآمن للمخططات</span></li>
                    <li><i class="fas fa-check"></i> <span data-lang="feat_hr">إدارة الموارد البشرية وتتبع الإنتاجية</span></li>
                    <li><i class="fas fa-check"></i> <span data-lang="feat_finance">النظام المالي وإصدار الفواتير</span></li>
                    <li><i class="fas fa-check"></i> <span data-lang="feat_portal">بوابة ملاك المشاريع الرقمية</span></li>
                </ul>

                <a class="pricing-cta-btn" asp-controller="Account" asp-action="Login">
                    <span data-lang="pricing_cta">ابدأ الآن</span>
                </a>
            </div>

            <!-- ── Growth Plan (Popular) ── -->
            <div class="pricing-card pricing-card--popular">
                <div class="pricing-popular-badge">
                    <i class="fas fa-star"></i>
                    <span data-lang="popular_badge">الأكثر طلباً · Most Popular</span>
                </div>

                <div class="pricing-card-header">
                    <div class="pricing-plan-icon gold">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div>
                        <h3 class="pricing-plan-name" data-lang="plan2_name">Growth</h3>
                        <p class="pricing-plan-name-ar" data-lang="plan2_name_ar">باقة النمو</p>
                    </div>
                </div>

                <div class="pricing-price-block">
                    <span class="pricing-price" data-lang="plan2_price">٨,٠٠٠</span>
                    <span class="pricing-currency" data-lang="plan2_currency">ج.م / شهرياً</span>
                </div>

                <div class="pricing-limits">
                    <div class="pricing-limit-item">
                        <i class="fas fa-users"></i>
                        <div>
                            <span class="limit-number">50</span>
                            <span class="limit-label" data-lang="limit_engineers">مهندس</span>
                        </div>
                    </div>
                    <div class="pricing-limit-divider"></div>
                    <div class="pricing-limit-item">
                        <i class="fas fa-folder-open"></i>
                        <div>
                            <span class="limit-number">15</span>
                            <span class="limit-label" data-lang="limit_projects">مشاريع نشطة</span>
                        </div>
                    </div>
                </div>

                <p class="pricing-desc" data-lang="plan2_desc">
                    الخيار المثالي للمكاتب الهندسية المتوسطة والمتنامية التي تدير مشاريع متعددة وفرق عمل أكبر بكامل الصلاحيات.
                </p>

                <ul class="pricing-features-list">
                    <li><i class="fas fa-check"></i> <span data-lang="feat_kanban">لوحة إدارة وتكليف المهام</span></li>
                    <li><i class="fas fa-check"></i> <span data-lang="feat_archive">الأرشيف السحابي الآمن للمخططات</span></li>
                    <li><i class="fas fa-check"></i> <span data-lang="feat_hr">إدارة الموارد البشرية وتتبع الإنتاجية</span></li>
                    <li><i class="fas fa-check"></i> <span data-lang="feat_finance">النظام المالي وإصدار الفواتير</span></li>
                    <li><i class="fas fa-check"></i> <span data-lang="feat_portal">بوابة ملاك المشاريع الرقمية</span></li>
                </ul>

                <a class="pricing-cta-btn pricing-cta-btn--popular" asp-controller="Account" asp-action="Login">
                    <span data-lang="pricing_cta">ابدأ الآن</span>
                </a>
            </div>

            <!-- ── Scale Plan ── -->
            <div class="pricing-card">
                <div class="pricing-card-header">
                    <div class="pricing-plan-icon purple">
                        <i class="fas fa-building"></i>
                    </div>
                    <div>
                        <h3 class="pricing-plan-name" data-lang="plan3_name">Scale</h3>
                        <p class="pricing-plan-name-ar" data-lang="plan3_name_ar">باقة المؤسسات</p>
                    </div>
                </div>

                <div class="pricing-price-block">
                    <span class="pricing-price" data-lang="plan3_price">١٦,٠٠٠</span>
                    <span class="pricing-currency" data-lang="plan3_currency">ج.م / شهرياً</span>
                </div>

                <div class="pricing-limits">
                    <div class="pricing-limit-item">
                        <i class="fas fa-users"></i>
                        <div>
                            <span class="limit-number">100</span>
                            <span class="limit-label" data-lang="limit_engineers">مهندس</span>
                        </div>
                    </div>
                    <div class="pricing-limit-divider"></div>
                    <div class="pricing-limit-item">
                        <i class="fas fa-folder-open"></i>
                        <div>
                            <span class="limit-number">40</span>
                            <span class="limit-label" data-lang="limit_projects">مشاريع نشطة</span>
                        </div>
                    </div>
                </div>

                <p class="pricing-desc" data-lang="plan3_desc">
                    مصممة للشركات والمكاتب الاستشارية الكبرى وبيوت الخبرة التي تدير حجم أعمال ضخم ومتعدد الفروع.
                </p>

                <ul class="pricing-features-list">
