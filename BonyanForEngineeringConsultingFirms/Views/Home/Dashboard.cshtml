@model BonyanForEngineeringConsultingFirms.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard - Analytics";
}

<link rel="stylesheet" href="~/css/dashboard.css" />

<style>
    .db-metrics-grid,
    .db-charts-grid,
    .db-tables-grid {
        display: grid !important;
        box-sizing: border-box !important;
        width: 100% !important;
    }

    .db-metrics-grid {
        grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
        gap: 16px !important;
        margin-bottom: 24px !important;
    }

    .db-charts-grid,
    .db-tables-grid {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) !important;
        gap: 20px !important;
        margin-bottom: 24px !important;
    }

    .db-metric-card,
    .db-panel {
        display: flex !important;
        flex-direction: column !important;
        min-width: 0 !important;
        overflow: hidden !important;
    }
</style>
<div class="bonyan-strict-wrapper container-fluid px-4 py-3">

    <div class="db-page-header">
        <div>
            <h2 class="db-page-title">
                <i class="fas fa-chart-pie"></i>
                <span data-lang="db_title">Dashboard</span>
            </h2>
            <p class="db-page-sub" data-lang="db_subtitle">Real-time engineering workspace performance & statistics</p>
        </div>
    </div>

    <div class="db-metrics-grid">

        <div class="db-metric-card" style="--accent: #007bff;">
            <div class="db-mc-top">
                <div class="db-mc-icon" style="background: linear-gradient(135deg, #007bff, #0056b3);">
                    <i class="fas fa-project-diagram"></i>
                </div>
                <div class="db-mc-info">
                    <div class="db-mc-number">@Model.TotalProjects</div>
                    <div class="db-mc-label" data-lang="db_total_projects">Total Projects</div>
                </div>
            </div>
            <div class="db-mc-bar-group">
                <div class="db-mc-bar-seg" style="background: #28a745; flex: @(Model.ProjCompleted + 1);"></div>
                <div class="db-mc-bar-seg" style="background: #17a2b8; flex: @(Model.ProjInProgress + 1);"></div>
                <div class="db-mc-bar-seg" style="background: #ffc107; flex: @(Model.ProjPlanning + 1);"></div>
            </div>
            <div class="db-mc-footer">
                <span class="db-mc-total" data-lang="db_all_projects_budget2">All registered projects</span>
            </div>
        </div>

        <div class="db-metric-card" style="--accent: #28a745;">
            <div class="db-mc-top">
                <div class="db-mc-icon" style="background: linear-gradient(135deg, #28a745, #1e7e34);">
                    <i class="fas fa-tasks"></i>
                </div>
                <div class="db-mc-info">
                    <div class="db-mc-number">@Model.ActiveTasks</div>
                    <div class="db-mc-label" data-lang="db_active_tasks">Active Tasks</div>
                </div>
            </div>
            <div class="db-mc-bar-group">
                <div class="db-mc-bar-seg" style="background: #28a745; flex: 100;"></div>
            </div>
            <div class="db-mc-footer">
                <span class="db-mc-badge green" data-lang="db_inprogress_label">In Progress</span>
            </div>
        </div>

        <div class="db-metric-card" style="--accent: #ffc107;">
            <div class="db-mc-top">
                <div class="db-mc-icon" style="background: linear-gradient(135deg, #ffc107, #d39e00);">
                    <i class="fas fa-users"></i>
                </div>
                <div class="db-mc-info">
                    <div class="db-mc-number">@Model.TotalClients</div>
                    <div class="db-mc-label" data-lang="db_total_clients">Total Clients</div>
                </div>
            </div>
            <div class="db-mc-bar-group">
                <div class="db-mc-bar-seg" style="background: #ffc107; flex: 100;"></div>
            </div>
            <div class="db-mc-footer">
                <span class="db-mc-total" data-lang="db_unique_clients">Distinct client base</span>
            </div>
        </div>

        <div class="db-metric-card" style="--accent: #17a2b8;">
            <div class="db-mc-top">
                <div class="db-mc-icon" style="background: linear-gradient(135deg, #17a2b8, #117a8b);">
                    <i class="fas fa-folder-open"></i>
                </div>
                <div class="db-mc-info">
                    <div class="db-mc-number">@Model.TotalDocuments</div>
                    <div class="db-mc-label" data-lang="db_total_docs">Documents</div>
                </div>
            </div>
            <div class="db-mc-bar-group">
                <div class="db-mc-bar-seg" style="background: #17a2b8; flex: 100;"></div>
            </div>
            <div class="db-mc-footer">
                <span class="db-mc-total" data-lang="db_files_label">Files & Drawings</span>
            </div>
        </div>

        <div class="db-metric-card" style="--accent: #dc3545;">
            <div class="db-mc-top">
                <div class="db-mc-icon" style="background: linear-gradient(135deg, #dc3545, #bd2130);">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div class="db-mc-info">
                    <div class="db-mc-number db-mc-budget">@Model.TotalBudget.ToString("C0")</div>
                    <div class="db-mc-label" data-lang="db_total_budget">Total Budget</div>
                </div>
            </div>
            <div class="db-mc-bar-group">
                <div class="db-mc-bar-seg" style="background: #dc3545; flex: 100;"></div>
            </div>
            <div class="db-mc-footer">
                <span class="db-mc-total" data-lang="db_project_finances">Project Finances</span>
            </div>
        </div>

    </div>

    <div class="db-charts-grid">

        <div class="db-panel">
            <div class="db-panel-header">
                <h3 class="db-panel-title">
                    <i class="fas fa-chart-bar"></i> <span data-lang="db_chart_projects">Projects by Status</span>
                </h3>
            </div>
            <div class="db-chart-wrap" style="height: 300px; position: relative;">
                <canvas id="projectsBarChart"></canvas>
            </div>
        </div>

        <div class="db-panel">
            <div class="db-panel-header">
                <h3 class="db-panel-title">
                    <i class="fas fa-chart-pie"></i> <span data-lang="db_chart_tasks">Tasks by Status</span>
                </h3>
            </div>
            <div class="db-chart-wrap db-doughnut-wrap" style="height: 300px; position: relative;">
                <canvas id="tasksDoughnutChart"></canvas>
            </div>
        </div>

    </div>

    <div class="db-tables-grid">

        <div class="db-panel">
            <div class="db-panel-header">
                <h3 class="db-panel-title">
                    <i class="fas fa-folder-plus"></i> <span data-lang="db_recent_projects">Recent Projects</span>
                </h3>
                <a asp-controller="Project" asp-action="Index" class="db-view-all" data-lang="view_all">View All</a>
            </div>
            <div class="db-table-wrap">
                @if (Model.RecentProjects != null && Model.RecentProjects.Any())
                {
                    <table class="db-table table m-0 table-hover">
                        <thead>
                            <tr>
                                <th data-lang="project_name">PROJECT</th>
                                <th data-lang="client">CLIENT</th>
                                <th data-lang="status">STATUS</th>
                                <th class="text-center" data-lang="tasks_col">TASKS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var proj in Model.RecentProjects)
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Project" asp-action="Details" asp-route-id="@proj.ProjectId" class="db-proj-link">
                                            @proj.ProjectName
                                        </a>
                                    </td>
                                    <td class="db-muted">@proj.ClientName</td>
                                    <td>
                                        <span class="db-mc-badge @(proj.Status == Bonyan.DAL.Enums.ProjectStatus.InProgress ? "teal" :
                                                                                                                                                                proj.Status == Bonyan.DAL.Enums.ProjectStatus.Completed ? "green" :
                                                                                                                                                                proj.Status == Bonyan.DAL.Enums.ProjectStatus.Planning ? "amber" : "purple")">
                                    @proj.Status
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="db-task-count">@proj.TaskCount</span>
                            </td>
                        </tr>
                                                }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="db-empty">
                        <i class="fas fa-folder-open"></i>
                        <span data-lang="db_no_recent_projects">No recent projects found</span>
                    </div>
                }
            </div>
        </div>

        <div class="db-panel db-panel-overdue">
            <div class="db-panel-header">
                <h3 class="db-panel-title db-overdue-title">
                    <i class="fas fa-exclamation-triangle"></i> <span data-lang="db_overdue_tasks">Overdue Tasks</span>
                </h3>
                <a asp-controller="Task" asp-action="Index" class="db-view-all" data-lang="view_all">View All</a>
            </div>
            <div class="db-overdue-list">
                @if (Model.OverdueTasks != null && Model.OverdueTasks.Any())
                {
                    @foreach (var task in Model.OverdueTasks)
                    {
                        <div class="db-overdue-item">
                            <div class="db-overdue-icon">
                                <i class="fas fa-clock"></i>
                            </div>
                            <div class="db-overdue-body">
                                <h4 class="db-overdue-name">@task.TaskName</h4>
                                <p class="db-overdue-project">
                                    <i class="fas fa-project-diagram"></i> @task.ProjectName
                                </p>
                            </div>
                            <div class="db-overdue-meta">
                                <span class="db-overdue-date">@task.DueDate.ToString("dd MMM yyyy")</span>
                                <span class="db-overdue-late">
                                    <i class="fas fa-hourglass-end"></i> <span data-lang="overdue_label">Overdue</span>
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="db-empty db-empty-good">
                        <i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i>
                        <span style="color: #28a745; font-weight: bold; margin-top: 8px;" data-lang="no_overdue">Great! No overdue tasks.</span>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const isDarkMode = document.body.classList.contains('dark-mode');
            const textMutedColor = isDarkMode ? '#8899aa' : '#888888';
            const gridBorderColor = isDarkMode ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';

            // 1. Bar Chart
            const ctxBar = document.getElementById('projectsBarChart').getContext('2d');
            new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: ['Planning', 'InProgress', 'OnHold', 'Completed', 'Cancelled'],
                    datasets: [{
                        label: 'Projects',
                        data: [@Model.ProjPlanning, @Model.ProjInProgress, @Model.ProjOnHold, @Model.ProjCompleted, @Model.ProjCancelled],
                        backgroundColor: ['#4bc0c0', '#2ecc71', '#f1c40f', '#e74c3c', '#9b59b6'],
                        borderRadius: 6,
                        barThickness: 25
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { grid: { color: gridBorderColor }, ticks: { color: textMutedColor, stepSize: 1 } },
                        x: { grid: { display: false }, ticks: { color: textMutedColor } }
                    }
                }
            });

            // 2. Doughnut Chart
            const ctxDoughnut = document.getElementById('tasksDoughnutChart').getContext('2d');
            new Chart(ctxDoughnut, {
                type: 'doughnut',
                data: {
                    labels: ['ToDo', 'InProgress', 'UnderReview', 'Completed', 'Cancelled'],
                    datasets: [{
                        data: [@Model.TaskPending, @Model.TaskInProgress, @Model.TaskUnderReview, @Model.TaskCompleted, @Model.TaskCancelled],
                        backgroundColor: ['#3498db', '#f39c12', '#9b59b6', '#2ecc71', '#e74c3c'],
                        borderWidth: isDarkMode ? 3 : 2,
                        borderColor: isDarkMode ? '#1a2535' : '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: textMutedColor, padding: 10, font: { size: 11, weight: '600' }, usePointStyle: true, pointStyle: 'rectRounded' }
                        }
                    },
                    cutout: '70%'
                }
            });
        });
    </script>
}