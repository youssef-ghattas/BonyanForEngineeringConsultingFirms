@model Bonyan.DAL.Models.Task
@using Bonyan.DAL.Enums
@{
    ViewData["Title"] = "تعديل المهمة";
    string projectName = ViewBag.ProjectName ?? "—";
    var engineers = ViewBag.Engineers as List<Bonyan.DAL.Models.Employee> ?? new List<Bonyan.DAL.Models.Employee>();
}

<link rel="stylesheet" href="~/css/task.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-edit" style="color:var(--secondary)"></i>
            تعديل المهمة
        </h2>
    </div>
    <a asp-controller="Project" asp-action="Details"
       asp-route-id="@Model.ProjectId" class="btn-bonyan-primary">
        <i class="fas fa-arrow-right"></i> رجوع للمشروع
    </a>
</div>

<div class="upload-card">
    <div class="upload-card-header">
        <i class="fas fa-edit"></i>
        <h4>تعديل بيانات المهمة</h4>
    </div>
    <div class="upload-card-body">

        <div class="project-badge">
            <i class="fas fa-project-diagram"></i>
            @projectName
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="TaskId" />
            <input type="hidden" asp-for="ProjectId" />
            <input type="hidden" asp-for="CreatedBy_UserID" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="form-group">
                <label>اسم المهمة <span style="color:red">*</span></label>
                <input asp-for="Task_Name" class="form-control" required />
                <span asp-validation-for="Task_Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>تعيين إلى مهندس</label>
                <select asp-for="AssignedToEmployeeId" class="form-select">
                    <option value="">-- بدون تعيين --</option>
                    @foreach (var eng in engineers)
                    {
                        if (Model.AssignedToEmployeeId == eng.EmployeeId)
                        {
                            <option value="@eng.EmployeeId" selected>@eng.FirstName @eng.LastName</option>
                        }
                        else
                        {
                            <option value="@eng.EmployeeId">@eng.FirstName @eng.LastName</option>
                        }
                    }
                </select>
            </div>

            <div class="form-group">
                <label>الحالة</label>
                <select asp-for="Status" class="form-select">
                    <option value="0">معلق</option>
                    <option value="1">جاري</option>
                    <option value="2">قيد المراجعة</option>
                    <option value="3">مكتمل</option>
                    <option value="4">ملغي</option>
                </select>
            </div>

            <div class="form-group">
                <label>الموعد النهائي</label>
                <input asp-for="DueDate" type="date" class="form-control" />
            </div>

            <div class="form-group">
                <label>ملاحظات</label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="upload-actions">
                <a asp-controller="Project" asp-action="Details"
                   asp-route-id="@Model.ProjectId" class="btn-bonyan-primary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
            </div>
        </form>
    </div>
</div>