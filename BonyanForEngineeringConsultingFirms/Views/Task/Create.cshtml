@model Bonyan.DAL.Models.Task
@using Bonyan.DAL.Enums
@{
    ViewData["Title"] = "إضافة مهمة";
    int projectId = ViewBag.ProjectId ?? 0;
    string projectName = ViewBag.ProjectName ?? "—";
    var engineers = ViewBag.Engineers as List<Bonyan.DAL.Models.Employee> ?? new List<Bonyan.DAL.Models.Employee>();
}

<link rel="stylesheet" href="~/css/employee.css" />
<link rel="stylesheet" href="~/css/employee-dark.css" />
<link rel="stylesheet" href="~/css/Task.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-plus-circle" style="color:var(--secondary)"></i>
            <span data-lang="add_task_new">إضافة مهمة جديدة</span>
        </h2>
        <p data-lang="task_create_sub">إضافة مهمة جديدة وتعيينها لأحد المهندسين</p>
    </div>
    <a asp-controller="Project" asp-action="Details"
       asp-route-id="@projectId" class="btn-bonyan-primary">
        <i class="fas fa-arrow-right"></i> <span data-lang="back_to_project">رجوع للمشروع</span>
    </a>
</div>

<div class="form-card">
    <div class="form-card-header">
        <i class="fas fa-tasks"></i>
        <h4 data-lang="task_data">بيانات المهمة</h4>
    </div>
    <div class="form-card-body">

        <div class="project-badge">
            <i class="fas fa-project-diagram"></i>
            @projectName
        </div>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ProjectId" value="@projectId" />

            <div class="form-section-title">
                <i class="fas fa-info-circle"></i>
                <span data-lang="task_basic_info">المعلومات الأساسية</span>
            </div>
            <div class="form-grid-2">
                <div class="form-group" style="grid-column:1/-1">
                    <label>
                        <i class="fas fa-tag" style="color:var(--secondary);margin-left:4px"></i>
                        <span data-lang="task_name_label">اسم المهمة</span>
                        <span style="color:var(--danger,#e53935)">*</span>
                    </label>
                    <input asp-for="Task_Name" class="form-control"
                           data-lang-placeholder="task_name_placeholder" placeholder="أدخل اسم المهمة" required />
                    <span asp-validation-for="Task_Name" class="text-danger"></span>
                </div>

                <div class="form-group" style="grid-column:1/-1">
                    <label>
                        <i class="fas fa-sticky-note" style="color:var(--secondary);margin-left:4px"></i>
                        <span data-lang="notes">ملاحظات</span>
                    </label>
                    <textarea asp-for="Notes" class="form-control"
                              rows="3" data-lang-placeholder="notes_placeholder" placeholder="أي ملاحظات..."></textarea>
                </div>
            </div>

            <div class="form-section-title" style="margin-top:28px">
                <i class="fas fa-users-cog"></i>
                <span data-lang="task_assignment">التعيين والحالة</span>
            </div>
            <div class="form-grid-2">
                <div class="form-group">
                    <label>
                        <i class="fas fa-user-tie" style="color:var(--secondary);margin-left:4px"></i>
                        <span data-lang="assign_to_engineer">تعيين إلى مهندس</span>
                    </label>
                    <div class="select-with-icon">
                        <i class="fas fa-chevron-down select-arrow"></i>
                        <select asp-for="AssignedToEmployeeId" class="form-select">
                            <option value="" data-lang="no_assignment_option">-- بدون تعيين --</option>
                            @foreach (var eng in engineers)
                            {
                                <option value="@eng.EmployeeId">
                                    @eng.FirstName @eng.LastName
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>
                        <i class="fas fa-calendar-clock" style="color:var(--secondary);margin-left:4px"></i>
                        <span data-lang="due_date">الموعد النهائي</span>
                    </label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                </div>

                <div class="form-group">
                    <label>
                        <i class="fas fa-circle" style="color:var(--secondary);margin-left:4px"></i>
                        <span data-lang="status">الحالة</span>
                    </label>
                    <select asp-for="Status" class="form-select status-select"
                            onchange="updateStatusPreview(this)">
                        <option value="0" data-lang="task_status_pending">معلق</option>
                        <option value="1" data-lang="task_status_inprogress">جاري</option>
                        <option value="2" data-lang="task_status_underreview">قيد المراجعة</option>
                        <option value="3" data-lang="task_status_completed">مكتمل</option>
                        <option value="4" data-lang="task_status_cancelled">ملغي</option>
                    </select>
                    <div id="statusPreview" class="task-status-badge badge-pending" style="margin-top:8px;display:none">
                        <i class="fas fa-circle"></i>
                        <span data-lang="task_status_pending">معلق</span>
                    </div>
                </div>
            </div>

            <div class="form-actions" style="margin-top:32px">
                <a asp-controller="Project" asp-action="Details"
                   asp-route-id="@projectId" class="btn-bonyan-primary">
                    <i class="fas fa-times"></i> <span data-lang="cancel">إلغاء</span>
                </a>
                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> <span data-lang="save_task">حفظ المهمة</span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var statusMap = {
            0: { cls: 'badge-pending',  icon: 'fa-circle',     label: 'معلق' },
            1: { cls: 'badge-inprogress',icon: 'fa-spinner',   label: 'جاري' },
            2: { cls: 'badge-review',    icon: 'fa-eye',       label: 'قيد المراجعة' },
            3: { cls: 'badge-completed', icon: 'fa-check-circle',label: 'مكتمل' },
            4: { cls: 'badge-cancelled', icon: 'fa-ban',       label: 'ملغي' }
        };
        function updateStatusPreview(sel) {
            var preview = document.getElementById('statusPreview');
            var val = sel.value;
            if (val === '') { preview.style.display = 'none'; return; }
            var m = statusMap[val];
            if (!m) return;
            preview.className = 'task-status-badge ' + m.cls;
            preview.querySelector('i').className = 'fas ' + m.icon;
            preview.querySelector('span').textContent = m.label;
            preview.style.display = 'inline-flex';
        }
        document.querySelector('.status-select').addEventListener('change', function() {
            updateStatusPreview(this);
        });
        var initial = document.querySelector('.status-select');
        if (initial && initial.value !== '') updateStatusPreview(initial);
    </script>
}
