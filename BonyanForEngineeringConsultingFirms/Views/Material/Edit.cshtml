@* ── SAVE AS: Views/Material/Edit.cshtml ── *@
@model Bonyan.DAL.Models.Material
@{
    ViewData["Title"] = "تعديل مادة";
}

<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-edit" style="color:var(--secondary)"></i>
            تعديل: @Model.MaterialName
        </h2>
    </div>
    <a asp-action="Details" asp-route-id="@Model.MaterialID" class="btn-bonyan-primary">
        <i class="fas fa-arrow-right"></i> رجوع للتفاصيل
    </a>
</div>

<div class="upload-card">
    <div class="upload-card-header">
        <i class="fas fa-cube"></i>
        <h4>تعديل بيانات المادة</h4>
    </div>
    <div class="upload-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MaterialID" />

            <div class="form-grid-2">
                <div class="form-group">
                    <label>اسم المادة <span style="color:red">*</span></label>
                    <input asp-for="MaterialName" class="form-control" required />
                    <span asp-validation-for="MaterialName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>وحدة القياس</label>
                    <select asp-for="Unit" class="form-control">
                        <option value="">-- اختر الوحدة --</option>
                        <option value="Kg">كيلوجرام</option>
                        <option value="Ton">طن</option>
                        <option value="Meter">متر</option>
                        <option value="SquareMeter">متر مربع</option>
                        <option value="CubicMeter">متر مكعب</option>
                        <option value="Piece">قطعة</option>
                    </select>
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>سعر الوحدة (ج.م)</label>
                    <input asp-for="UnitPrice" type="number" step="0.01" min="0" class="form-control" />
                    <span asp-validation-for="UnitPrice" class="text-danger"></span>
                </div>
                <div class="form-group" style="grid-column:1 / -1">
                    <label>الوصف</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="upload-actions">
                <a asp-action="Details" asp-route-id="@Model.MaterialID" class="btn-bonyan-primary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
            </div>
        </form>
    </div>
</div>
