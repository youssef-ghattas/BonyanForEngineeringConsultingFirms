@* ── SAVE AS: Views/Supplier/Edit.cshtml ── *@
@model Bonyan.DAL.Models.Supplier
@{
    ViewData["Title"] = "تعديل مورد";
}

<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-edit" style="color:var(--secondary)"></i>
            تعديل: @Model.SupplierName
        </h2>
    </div>
    <a asp-action="Details" asp-route-id="@Model.SupplierID" class="btn-bonyan-primary">
        <i class="fas fa-arrow-right"></i> رجوع للتفاصيل
    </a>
</div>

<div class="upload-card">
    <div class="upload-card-header">
        <i class="fas fa-industry"></i>
        <h4>تعديل بيانات المورد</h4>
    </div>
    <div class="upload-card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="SupplierID" />
            <div class="form-grid-2">
                <div class="form-group">
                    <label>اسم المورد <span style="color:red">*</span></label>
                    <input asp-for="SupplierName" class="form-control" required />
                    <span asp-validation-for="SupplierName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>شخص التواصل <span style="color:red">*</span></label>
                    <input asp-for="ContactPerson" class="form-control" required />
                    <span asp-validation-for="ContactPerson" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>البريد الإلكتروني <span style="color:red">*</span></label>
                    <input asp-for="Email" type="email" class="form-control" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>الهاتف <span style="color:red">*</span></label>
                    <input asp-for="Phone" class="form-control" required />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="form-group" style="grid-column:1 / -1">
                    <label>العنوان <span style="color:red">*</span></label>
                    <textarea asp-for="Address" class="form-control" rows="2" required></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>
            <div class="upload-actions">
                <a asp-action="Details" asp-route-id="@Model.SupplierID" class="btn-bonyan-primary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> حفظ التعديلات
                </button>
            </div>
        </form>
    </div>
</div>
