@* Views/Supplier/Create.cshtml *@
@model Bonyan.DAL.Models.Supplier
@{
    ViewData["Title"] = "إضافة مورد";
    var allMaterials = ViewBag.AllMaterials as List<Bonyan.DAL.Models.Material> ?? new();
}

<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-plus-circle" style="color:var(--secondary)"></i>
            إضافة مورد جديد
        </h2>
    </div>
    <a asp-action="Index" class="btn-bonyan-primary">
        <i class="fas fa-arrow-right"></i> رجوع للموردين
    </a>
</div>

<div class="upload-card">
    <div class="upload-card-header">
        <i class="fas fa-industry"></i>
        <h4>بيانات المورد</h4>
    </div>
    <div class="upload-card-body">
        <form asp-action="Create" method="post" id="supplierForm">
            @Html.AntiForgeryToken()

            <div class="form-grid-2">
                <div class="form-group">
                    <label>اسم المورد <span style="color:red">*</span></label>
                    <input asp-for="SupplierName" class="form-control" placeholder="اسم الشركة أو المورد" required />
                    <span asp-validation-for="SupplierName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>شخص التواصل <span style="color:red">*</span></label>
                    <input asp-for="ContactPerson" class="form-control" placeholder="اسم المسؤول" required />
                    <span asp-validation-for="ContactPerson" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>البريد الإلكتروني <span style="color:red">*</span></label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="supplier@example.com" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label>الهاتف <span style="color:red">*</span></label>
                    <input asp-for="Phone" class="form-control" placeholder="01xxxxxxxxx" required />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="form-group" style="grid-column:1 / -1">
                    <label>العنوان <span style="color:red">*</span></label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="عنوان المورد التفصيلي" required></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>

            @if (allMaterials.Any())
            {
                <hr style="margin: 20px 0;" />
                <div class="details-section-title" style="margin-bottom:12px">
                    <i class="fas fa-boxes"></i> تحديد المواد التي يورّدها (اختياري)
                </div>

                <div id="materialRows">
                    <div class="material-row" style="display:grid; grid-template-columns:2fr 1fr 1fr auto; gap:10px; align-items:end; margin-bottom:10px">
                        <div class="form-group" style="margin:0">
                            <label>المادة</label>
                            <select name="selectedMaterials" class="form-control">
                                <option value="">-- اختر مادة --</option>
                                @foreach (var m in allMaterials)
                                {
                                    <option value="@m.MaterialID">@m.MaterialName (@(m.Unit ?? "—"))</option>
                                }
                            </select>
                        </div>
                        <div class="form-group" style="margin:0">
                            <label>سعر التوريد (ج.م)</label>
                            <input type="number" name="supplyPrices" step="0.01" min="0"
                                   class="form-control" placeholder="0.00" />
                        </div>
                        <div class="form-group" style="margin:0">
                            <label>آخر توريد</label>
                            <input type="date" name="lastSupplyDates" class="form-control" />
                        </div>
                        <button type="button" onclick="removeRow(this)"
                                class="btn-action delete" style="margin-bottom:2px" title="حذف">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>

                <button type="button" onclick="addMaterialRow()"
                        class="btn-bonyan-primary" style="margin-bottom:16px; font-size:0.85rem">
                    <i class="fas fa-plus"></i> إضافة مادة أخرى
                </button>
            }

            <div class="upload-actions">
                <a asp-action="Index" class="btn-bonyan-primary">
                    <i class="fas fa-times"></i> إلغاء
                </a>
                <button type="submit" class="btn-bonyan-secondary">
                    <i class="fas fa-save"></i> حفظ المورد
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const materialOptions = `@Html.Raw(string.Join("", allMaterials.Select(m =>
                    $"<option value='{m.MaterialID}'>{m.MaterialName} ({m.Unit ?? "—"})</option>")))`;

    function addMaterialRow() {
        const container = document.getElementById('materialRows');
        const div = document.createElement('div');
        div.className = 'material-row';
        div.style.cssText = 'display:grid; grid-template-columns:2fr 1fr 1fr auto; gap:10px; align-items:end; margin-bottom:10px';
        div.innerHTML = `
            <div class="form-group" style="margin:0">
                <label>المادة</label>
                <select name="selectedMaterials" class="form-control">
                    <option value="">-- اختر مادة --</option>
                    ${materialOptions}
                </select>
            </div>
            <div class="form-group" style="margin:0">
                <label>سعر التوريد (ج.م)</label>
                <input type="number" name="supplyPrices" step="0.01" min="0" class="form-control" placeholder="0.00" />
            </div>
            <div class="form-group" style="margin:0">
                <label>آخر توريد</label>
                <input type="date" name="lastSupplyDates" class="form-control" />
            </div>
            <button type="button" onclick="removeRow(this)" class="btn-action delete" style="margin-bottom:2px" title="حذف">
                <i class="fas fa-trash"></i>
            </button>`;
        container.appendChild(div);
    }

        function removeRow(btn) {
            btn.closest('.material-row').remove();
        }

        // Before submit: remove rows where no material was selected
        document.getElementById('supplierForm').addEventListener('submit', function () {
            document.querySelectorAll('.material-row').forEach(row => {
                const sel = row.querySelector('select[name="selectedMaterials"]');
                if (!sel || !sel.value) row.remove();
            });
        });
    </script>
}