@model Bonyan.DAL.Models.Supplier
@{
    ViewData["Title"] = "تفاصيل المورد";
    var role = Context.Session.GetString("Role");
}

<link rel="stylesheet" href="~/css/employee.css" />
<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-industry" style="color:var(--secondary)"></i>
            @Model.SupplierName
        </h2>
    </div>
    <div style="display:flex; gap:10px">
        <a asp-action="Index" class="btn-bonyan-primary">
            <i class="fas fa-arrow-right"></i> <span data-lang="back_to_suppliers">رجوع للموردين</span>
        </a>
        @if (role == "Admin")
        {
            <a asp-action="Edit" asp-route-id="@Model.SupplierID" class="btn-bonyan-secondary">
                <i class="fas fa-edit"></i> <span data-lang="edit">تعديل</span>
            </a>
        }
    </div>
</div>

@await Html.PartialAsync("_AlertMessages")

<!-- Supplier Info Card -->
<div class="details-card">
    <div class="details-body">
        <div class="details-section">
            <div class="details-section-title" data-lang="supplier_data">بيانات المورد</div>
            <div class="details-grid">
                <div class="detail-item">
                    <label data-lang="supplier_name_label">اسم المورد</label>
                    <p>@Model.SupplierName</p>
                </div>
                <div class="detail-item">
                    <label data-lang="contact_person">شخص التواصل</label>
                    <p>@(Model.ContactPerson ?? "—")</p>
                </div>
                <div class="detail-item">
                    <label data-lang="email">البريد الإلكتروني</label>
                    <p><a href="mailto:@Model.Email" style="color:var(--secondary)">@(Model.Email ?? "—")</a></p>
                </div>
                <div class="detail-item">
                    <label data-lang="phone">الهاتف</label>
                    <p>@(Model.Phone ?? "—")</p>
                </div>
                <div class="detail-item" style="grid-column:1 / -1">
                    <label data-lang="address">العنوان</label>
                    <p>@(Model.Address ?? "—")</p>
                </div>
                <div class="detail-item" style="grid-column:1 / -1">
                    <label data-lang="supplied_materials">المواد المورَّدة</label>
                    <p>
                        @{
                            var types = (Model.SuppliedMaterialTypes ?? "")
                            .Split(',', StringSplitOptions.RemoveEmptyEntries);
                            var typeLabels = new Dictionary<string, string> {
                                        {"Steel","حديد"}, {"Sand","رمل"}, {"Cement","أسمنت"},
                                        {"Bricks","طوب"}
                                        };
                        }
                        @if (types.Any())
                        {
                            foreach (var t in types)
                            {
                                string display = t.StartsWith("Others:") ? "أخرى: " + t.Substring(7)
                                : (typeLabels.ContainsKey(t) ? typeLabels[t] : t);
                                string bgColor = t == "Steel" ? "#607d8b" : t == "Sand" ? "#ffa726" :
                                t == "Cement" ? "#90a4ae" : t == "Bricks" ? "#ef5350" : "#ab47bc";
                                <span style="display:inline-flex;align-items:center;gap:6px;
                                                     background:@bgColor;color:#fff;padding:3px 10px;
                                                     border-radius:16px;font-size:0.82rem;margin-left:6px;font-weight:600">
                                    @display
                                </span>
                            }
                        }
                        else
                        {
                            <span style="color:#aaa">—</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Supplied Materials -->
<div class="details-card">
    <div class="details-body">
        <div class="details-section">
            <div class="details-section-title">
                <i class="fas fa-boxes"></i> <span data-lang="supplied_materials">المواد المورَّدة</span>
                <span class="tab-count">@Model.SuppliedMaterials.Count</span>
            </div>

            @if (Model.SuppliedMaterials != null && Model.SuppliedMaterials.Any())
            {
                <table class="mat-table">
                    <thead>
                        <tr>
                            <th data-lang="material_name_label">اسم المادة</th>
                            <th data-lang="measurement_unit">وحدة القياس</th>
                            <th data-lang="supply_price">سعر التوريد</th>
                            <th data-lang="last_supply">آخر توريد</th>
                            <th data-lang="details">تفاصيل</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ms in Model.SuppliedMaterials)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Material" asp-action="Details"
                                       asp-route-id="@ms.MaterialID"
                                       style="color:var(--primary); font-weight:600; text-decoration:none">
                                        @(ms.Material?.MaterialName ?? "—")
                                    </a>
                                </td>
                                <td>
                                    @if (ms.Material?.Unit != null)
                                    {
                                        <span class="unit-badge">@ms.Material.Unit</span>
                                    }
                                    else
                                    {

                                        <span>—</span>
                                    }
                                </td>
                                <td>@(ms.SupplyPrice.HasValue? ms.SupplyPrice.Value.ToString("N2") + " ج.م" : "—")</td>
                                <td>@(ms.LastSupplyDate.HasValue? ms.LastSupplyDate.Value.ToString("yyyy-MM-dd") : "—")</td>
                                <td>
                                    <a asp-controller="Material" asp-action="Details"
                                       asp-route-id="@ms.MaterialID"
                                       class="btn-action view" title="عرض المادة">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color:#aaa; font-size:0.88rem" data-lang="no_linked_materials">لا توجد مواد مرتبطة بهذا المورد بعد</p>
            }
        </div>
    </div>
</div>
