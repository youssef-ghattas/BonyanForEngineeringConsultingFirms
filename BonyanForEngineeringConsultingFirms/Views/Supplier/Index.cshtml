@* ══════════════════════════════════════════════════
   SAVE AS: Views/Supplier/Index.cshtml
══════════════════════════════════════════════════ *@
@model IEnumerable<Bonyan.DAL.Models.Supplier>
@{
    ViewData["Title"] = "الموردون";
    var role = Context.Session.GetString("Role");
    string search = ViewBag.Search ?? "";
}

<link rel="stylesheet" href="~/css/material.css" />

<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-truck" style="color:var(--secondary)"></i>
            <span data-lang="suppliers">الموردون</span>
        </h2>
    </div>
    @if (role == "Admin")
    {
        <a asp-action="Create" class="btn-bonyan-secondary">
            <i class="fas fa-plus"></i> <span data-lang="add_supplier">إضافة مورد</span>
        </a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success-msg"><i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error-msg"><i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]</div>
}

<div class="filter-bar">
    <form method="get" asp-action="Index" style="display:flex; align-items:center; gap:10px; width:100%; max-width:420px">
        <div style="position:relative; flex:1">
            <i class="fas fa-search" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); color:#aaa; z-index:1"></i>
            <input type="text" name="search" value="@search" data-lang-placeholder="search_supplier" placeholder="بحث بالاسم أو البريد..."
                   class="form-control" style="padding-right:36px" />
        </div>
        <button type="submit" class="btn-bonyan-secondary" style="padding:8px 16px">
            <i class="fas fa-search"></i> <span data-lang="search">بحث</span>
        </button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Index" class="btn-bonyan-primary" style="padding:8px 16px">
                <i class="fas fa-times"></i> <span data-lang="cancel">إلغاء</span>
            </a>
        }
    </form>
</div>

<div class="details-card">
    @if (Model.Any())
    {
        <table class="mat-table">
            <thead>
                <tr>
                    <th data-lang="supplier_name_label">اسم المورد</th>
                    <th data-lang="contact_person">شخص التواصل</th>
                    <th data-lang="email">البريد الإلكتروني</th>
                    <th data-lang="phone">الهاتف</th>
                    <th data-lang="supplied_materials">المواد المورَّدة</th>
                    <th data-lang="actions">إجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@s.SupplierID"
                               style="color:var(--primary); font-weight:600; text-decoration:none">
                                <i class="fas fa-industry" style="font-size:0.65rem; color:var(--secondary); margin-left:6px"></i>
                                @s.SupplierName
                            </a>
                            @if (!string.IsNullOrWhiteSpace(s.Address))
                            {
                                <div style="font-size:0.78rem; color:#888; margin-top:2px">
                                    <i class="fas fa-map-marker-alt"></i> @s.Address
                                </div>
                            }
                        </td>
                        <td>@(s.ContactPerson ?? "—")</td>
                        <td>
                            <a href="mailto:@s.Email" style="color:var(--secondary); text-decoration:none">
                                @(s.Email ?? "—")
                            </a>
                        </td>
                        <td>@(s.Phone ?? "—")</td>
                        <td>
                            <span class="count-badge">
                                <i class="fas fa-boxes"></i> @s.SuppliedMaterials.Count
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@s.SupplierID"
                               class="btn-action view" title="عرض">
                                <i class="fas fa-eye"></i>
                            </a>
                            @if (role == "Admin")
                            {
                                <a asp-action="Edit" asp-route-id="@s.SupplierID"
                                   class="btn-action edit" title="تعديل">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@s.SupplierID" method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('هل أنت متأكد من حذف هذا المورد؟')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-action delete" title="حذف">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-truck"></i>
            <p>@(!string.IsNullOrEmpty(search) ? Html.Raw("<span data-lang=\"no_suppliers_match\">لا يوجد موردون تطابق البحث</span>") : Html.Raw("<span data-lang=\"no_suppliers\">لا يوجد موردون حتى الآن</span>"))</p>
        </div>
    }
</div>