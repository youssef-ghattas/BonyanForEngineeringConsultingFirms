@model IEnumerable<Bonyan.DAL.Models.Project>
@using Bonyan.DAL.Enums
@{
    ViewData["Title"] = "المشاريع";
    var role = Context.Session.GetString("Role");
}

<link rel="stylesheet" href="~/css/project.css" />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert"
         style="margin: 20px; text-align: right; direction: rtl;">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h2>
            <i class="fas fa-project-diagram"
               style="color:var(--secondary)"></i>
            <span data-lang="projects">المشاريع</span>
        </h2>
        <p data-lang="projects_sub">إدارة وتتبع المشاريع الهندسية</p>
    </div>
    @if (role == "Admin")
    {
        <a asp-action="Create" class="btn-bonyan-secondary">
            <i class="fas fa-plus"></i>
            <span data-lang="add_project">إضافة مشروع</span>
        </a>
    }
</div>

<!-- Filter Bar -->
<div class="filter-bar">
    <div class="filter-search">
        <i class="fas fa-search"></i>
        <input type="text" class="form-control" placeholder="بحث عن مشروع..."
               onkeyup="filterProjects()" />
    </div>
    <select class="filter-select" id="statusFilter"
            onchange="filterProjects()">
        <option value="" data-lang="all_statuses">كل الحالات</option>
        <option value="planning" data-lang="status_planning">تخطيط</option>
        <option value="inprogress" data-lang="status_inprogress">جاري</option>
        <option value="completed" data-lang="status_completed">مكتمل</option>
        <option value="onhold" data-lang="status_onhold">موقوف</option>
        <option value="cancelled" data-lang="status_cancelled">ملغي</option>
    </select>
</div>

<!-- Projects Grid -->
@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-folder-open"></i>
        <p data-lang="no_projects">لا توجد مشاريع حتى الآن</p>
    </div>
}
else
{
    <div class="projects-grid" id="projectsGrid">
        @foreach (var p in Model)
        {
            string badgeClass = p.Status switch
            {
                ProjectStatus.Planning => "badge-planning",
                ProjectStatus.InProgress => "badge-inprogress",
                ProjectStatus.Completed => "badge-completed",
                ProjectStatus.OnHold => "badge-onhold",
                ProjectStatus.Cancelled => "badge-cancelled",
                _ => "badge-planning"
            };
            string statusAr = p.Status switch
            {
                ProjectStatus.Planning => "تخطيط",
                ProjectStatus.InProgress => "جاري التنفيذ",
                ProjectStatus.Completed => "مكتمل",
                ProjectStatus.OnHold => "موقوف",
                ProjectStatus.Cancelled => "ملغي",
                _ => p.Status.ToString()
            };
            string statusKey = p.Status.ToString().ToLower();

            <div class="project-card" data-status="@statusKey"
                 data-name="@p.ProjectName.ToLower()">
                <div class="project-card-top">
                    <div class="project-card-header">
                        <div class="project-icon">
                            <i class="fas fa-hard-hat"></i>
                        </div>
                        <span class="badge-status @badgeClass"
                              data-en="@p.Status.ToString()"
                              data-ar="@statusAr">
                            @statusAr
                        </span>
                    </div>
                    <div class="project-card-title">@p.ProjectName</div>
                    <div class="project-card-client">
                        <i class="fas fa-user-tie"></i>
                        @(p.Client_Name ?? "—")
                    </div>
                    <div class="project-meta">
                        <div class="project-meta-item">
                            <label data-lang="start_date">تاريخ البدء</label>
                            <span>
                                @(p.StartDate.HasValue
                                                        ? p.StartDate.Value.ToString("yyyy-MM-dd")
                                                        : "—")
                                                          </span>
                                                      </div>
                                                      <div class="project-meta-item">
                                                          <label data-lang="end_date">تاريخ الانتهاء</label>
                                                          <span>
                                @(p.EndDate.HasValue
                                                        ? p.EndDate.Value.ToString("yyyy-MM-dd")
                                                        : "—")
                                                          </span>
                                                      </div>
                                                      <div class="project-meta-item">
                                                          <label data-lang="budget">الميزانية</label>
                                                          <span>
                                @(p.Budget.HasValue
                                                        ? p.Budget.Value.ToString("N0") + " ج.م"
                                                        : "—")
                    </span>
                </div>
                <div class="project-meta-item">
                    <label data-lang="location">الموقع</label>
                    <span>@(p.Location ?? "—")</span>
                </div>
            </div>
        </div>
        <div class="project-card-footer">
            <div class="project-team">
                <i class="fas fa-users"></i>
                <span>
                    @p.EmployeeProjects.Count
                    <span data-lang="members">عضو</span>
                </span>
            </div>
            <div class="project-actions">
                <a asp-action="Details"
                   asp-route-id="@p.ProjectId"
                   class="btn-action view" title="تفاصيل">
                    <i class="fas fa-eye"></i>
                </a>
                @if (role == "Admin")
                        {
                            <a asp-action="Edit"
                               asp-route-id="@p.ProjectId"
                               class="btn-action edit" title="تعديل">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete"
                               asp-route-id="@p.ProjectId"
                               class="btn-action delete" title="حذف">
                                <i class="fas fa-trash"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        function filterProjects() {
            const search = document.getElementById('searchInput')
                                   .value.toLowerCase();
            const status = document.getElementById('statusFilter')
                                   .value.toLowerCase();
            const cards  = document.querySelectorAll('.project-card');

            cards.forEach(card => {
                const name      = card.getAttribute('data-name') || '';
                const cardStatus = card.getAttribute('data-status') || '';

                const matchSearch = name.includes(search);
                const matchStatus = status === '' || cardStatus === status;

                card.style.display = (matchSearch && matchStatus) ? '' : 'none';
            });
        }
    </script>
}