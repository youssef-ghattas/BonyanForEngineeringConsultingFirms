@model Bonyan.PL.ViewModels.ChangePasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title data-lang="change_password_title">تغيير كلمة المرور - بُنيَان</title>
    <script>
        (function () {
            const savedLang = localStorage.getItem("lang") || "ar";
            document.documentElement.setAttribute("lang", savedLang);
            document.documentElement.setAttribute("dir", savedLang === "ar" ? "rtl" : "ltr");
        })();
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Login.css" />
    <link rel="stylesheet" href="~/css/changepassword.css" />
    <link rel="stylesheet" href="~/css/auth-theme.css" />
</head>
<body>
    <script>
        (function () {
            const saved = localStorage.getItem('bonyan-dark');
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (saved === '1' || (saved === null && prefersDark)) document.body.classList.add('dark-mode');
        })();
    </script>
    <button id="langBtn" onclick="toggleLanguage()"
            style="position:fixed; top:22px; left:76px; z-index:999; background:#fff;
                   border:1px solid #ddd; border-radius:20px; padding:7px 16px;
                   font-size:0.85rem; font-weight:600; color:#333; cursor:pointer;
                   box-shadow:0 2px 8px rgba(0,0,0,0.08); display:flex; align-items:center; gap:6px;">
        <i class="fas fa-globe"></i>
        <span id="langBtnText">English</span>
    </button>
    <div class="login-wrapper">

        <!-- Left Panel -->
        <div class="login-left">
            <div class="logo-icon">
                <i class="fas fa-key"></i>
            </div>
            <h1 data-lang="Landing_Badge">بُنيَان</h1>
            <div class="divider"></div>
            <p data-lang="change_password_required">
                تغيير كلمة المرور إلزامي عند أول تسجيل دخول لحماية حسابك
            </p>

            <div class="steps-list">
                <div class="step-item">
                    <div class="step-num">1</div>
                    <span data-lang="step_enter_current">أدخل كلمة المرور الحالية</span>
                </div>
                <div class="step-item">
                    <div class="step-num">2</div>
                    <span data-lang="step_choose_new">اختر كلمة مرور جديدة قوية</span>
                </div>
                <div class="step-item">
                    <div class="step-num">3</div>
                    <span data-lang="step_confirm_new">تأكيد كلمة المرور الجديدة</span>
                </div>
            </div>

            <div class="info-box">
                <p>
                    <i class="fas fa-shield-alt"></i>
                    &nbsp;<span data-lang="md5_hint">كلمة المرور محمية بتشفير MD5</span>
                </p>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="login-right">
            <h2 data-lang="change_password">تغيير كلمة المرور 🔐</h2>
            <p data-lang="change_password_sub">أدخل كلمة المرور الحالية ثم اختر كلمة مرور جديدة</p>

            @if (TempData["SuccessMessageKey"] != null)
            {
                <div class="success-alert">
                    <i class="fas fa-check-circle"></i>
                    <span data-lang="@TempData["SuccessMessageKey"]">@TempData["Success"]</span>
                </div>
            }
            else if (TempData["Success"] != null)
            {
                <div class="success-alert">
                    <i class="fas fa-check-circle"></i>
                    @TempData["Success"]
                </div>
            }

            <form method="post" asp-action="ChangePassword" asp-controller="Account">
                @Html.AntiForgeryToken()

                <!-- Current Password -->
                <div class="field-group">
                    <label class="form-label" data-lang="current_password">
                        كلمة المرور الحالية
                    </label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="CurrentPassword"
                               type="password"
                               id="currentPwd"
                               class="form-control"
                               data-lang-placeholder="current_password_placeholder" placeholder="أدخل كلمة المرور الحالية" />
                        <i class="fas fa-eye toggle-password"
                           data-target="currentPwd"></i>
                    </div>
                    <span asp-validation-for="CurrentPassword"
                          class="text-danger"
                          style="font-size:0.82rem"></span>
                </div>

                <!-- New Password -->
                <div class="field-group">
                    <label class="form-label" data-lang="new_password_label">
                        كلمة المرور الجديدة
                    </label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="NewPassword"
                               type="password"
                               id="newPwd"
                               class="form-control"
                               data-lang-placeholder="new_password_placeholder" placeholder="أدخل كلمة المرور الجديدة" />
                        <i class="fas fa-eye toggle-password"
                           data-target="newPwd"></i>
                    </div>
                    <span asp-validation-for="NewPassword"
                          class="text-danger"
                          style="font-size:0.82rem"></span>
                </div>

                <!-- Confirm New Password -->
                <div class="field-group">
                    <label class="form-label" data-lang="confirm_new_password">
                        تأكيد كلمة المرور الجديدة
                    </label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="ConfirmNewPassword"
                               type="password"
                               id="confirmPwd"
                               class="form-control"
                               data-lang-placeholder="confirm_new_password_placeholder" placeholder="أعد إدخال كلمة المرور الجديدة" />
                        <i class="fas fa-eye toggle-password"
                           data-target="confirmPwd"></i>
                    </div>
                    <span asp-validation-for="ConfirmNewPassword"
                          class="text-danger"
                          style="font-size:0.82rem"></span>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-save"></i>
                    <span data-lang="save_new_password">حفظ كلمة المرور الجديدة</span>
                </button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/translations.js"></script>
    <script src="~/js/lang-switch.js"></script>
    <script src="~/js/show-password.js"></script>
    <script src="~/js/auth-theme.js"></script>
</body>
</html>