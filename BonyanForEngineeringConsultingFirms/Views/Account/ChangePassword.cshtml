@model Bonyan.PL.ViewModels.ChangePasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تغيير كلمة المرور - بنيان</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Login.css" />
    <style>
        .info-box {
            margin-top: 24px;
            background: rgba(200, 146, 42, 0.15);
            border-radius: 12px;
            padding: 16px 20px;
        }

            .info-box p {
                color: #C8922A !important;
                font-size: 0.85rem !important;
                margin: 0 !important;
                line-height: 1.6 !important;
            }

        .steps-list {
            margin-top: 20px;
            text-align: right;
        }

        .step-item {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
            color: rgba(255,255,255,0.8);
            font-size: 0.88rem;
        }

        .step-num {
            width: 26px;
            height: 26px;
            background: rgba(200,146,42,0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            font-weight: 700;
            color: #C8922A;
            flex-shrink: 0;
        }

        .success-alert {
            background: #EEFAF2;
            border: 1px solid #C3EDD0;
            border-radius: 10px;
            padding: 12px 16px;
            color: #28A745;
            font-size: 0.88rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .field-group {
            margin-bottom: 18px;
        }

            .field-group .input-group {
                margin-bottom: 4px;
            }
    </style>
</head>
<body>
    <div class="login-wrapper">

        <!-- Left Panel -->
        <div class="login-left">
            <div class="logo-icon">
                <i class="fas fa-key"></i>
            </div>
            <h1>بنيان</h1>
            <div class="divider"></div>
            <p>تغيير كلمة المرور إلزامي عند أول تسجيل دخول لحماية حسابك</p>

            <div class="steps-list">
                <div class="step-item">
                    <div class="step-num">1</div>
                    <span>أدخل كلمة المرور الحالية</span>
                </div>
                <div class="step-item">
                    <div class="step-num">2</div>
                    <span>اختر كلمة مرور جديدة قوية</span>
                </div>
                <div class="step-item">
                    <div class="step-num">3</div>
                    <span>تأكيد كلمة المرور الجديدة</span>
                </div>
            </div>

            <div class="info-box">
                <p>
                    <i class="fas fa-shield-alt"></i>
                    &nbsp;كلمة المرور محمية بتشفير MD5
                </p>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="login-right">
            <h2>تغيير كلمة المرور 🔐</h2>
            <p>أدخل كلمة المرور الحالية ثم اختر كلمة مرور جديدة</p>

            @if (TempData["Success"] != null)
            {
                <div class="success-alert">
                    <i class="fas fa-check-circle"></i>
                    @TempData["Success"]
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="error-alert">
                    <i class="fas fa-exclamation-circle"></i>
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-action="ChangePassword" asp-controller="Account">
                @Html.AntiForgeryToken()

                <!-- Current Password -->
                <div class="field-group">
                    <label class="form-label">كلمة المرور الحالية</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="CurrentPassword"
                               type="password"
                               class="form-control"
                               placeholder="أدخل كلمة المرور الحالية" />
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger" style="font-size:0.82rem"></span>
                </div>

                <!-- New Password -->
                <div class="field-group">
                    <label class="form-label">كلمة المرور الجديدة</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="NewPassword"
                               type="password"
                               class="form-control"
                               placeholder="أدخل كلمة المرور الجديدة" />
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger" style="font-size:0.82rem"></span>
                </div>

                <!-- Confirm New Password -->
                <div class="field-group">
                    <label class="form-label">تأكيد كلمة المرور الجديدة</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="ConfirmNewPassword"
                               type="password"
                               class="form-control"
                               placeholder="أعد إدخال كلمة المرور الجديدة" />
                    </div>
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger" style="font-size:0.82rem"></span>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-save"></i>
                    حفظ كلمة المرور الجديدة
                </button>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>