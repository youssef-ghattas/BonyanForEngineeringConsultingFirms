@{
    Layout = null;
}
@using Bonyan.DAL.Enums
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title data-lang="register_title">إنشاء حساب - بُنيَان</title>
    <script>
        (function () {
            const savedLang = localStorage.getItem("lang") || "ar";
            document.documentElement.setAttribute("lang", savedLang);
            document.documentElement.setAttribute("dir", savedLang === "ar" ? "rtl" : "ltr");
        })();
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/login.css" />
    <link rel="stylesheet" href="~/css/register.css" />
    <link rel="stylesheet" href="~/css/auth-theme.css" />
</head>
<body>
    <script>
        (function () {
            const saved = localStorage.getItem('bonyan-dark');
            const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            if (saved === '1' || (saved === null && prefersDark)) document.body.classList.add('dark-mode');
        })();
    </script>
    <button id="langBtn" onclick="toggleLanguage()"
            style="position:fixed; top:22px; left:76px; z-index:999; background:#fff;
                   border:1px solid #ddd; border-radius:20px; padding:7px 16px;
                   font-size:0.85rem; font-weight:600; color:#333; cursor:pointer;
                   box-shadow:0 2px 8px rgba(0,0,0,0.08); display:flex; align-items:center; gap:6px;">
        <i class="fas fa-globe"></i>
        <span id="langBtnText">English</span>
    </button>
    <div class="register-wrapper">

        <!-- Left Panel -->
        <div class="login-left">
            <div class="logo-icon">
                <i class="fas fa-building"></i>
            </div>
            <h1 data-lang="Landing_Badge">بُنيَان</h1>
            <div class="divider"></div>
            <p data-lang="register_left_desc">أنشئ حسابك للانضمام إلى منصة بُنيَان لإدارة المشاريع الهندسية</p>
        </div>

        <!-- Right Panel -->
        <div class="login-right register-right">
            <h2 data-lang="register_heading">إنشاء حساب جديد</h2>
            <p data-lang="register_sub">أدخل بياناتك للتسجيل</p>

            @if (ViewBag.Error != null)
            {
                <div class="error-alert">
                    <i class="fas fa-exclamation-circle"></i>
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-action="Register" asp-controller="Account">
                @Html.AntiForgeryToken()

                <!-- Row 1: First + Last Name -->
                <div class="form-row-2">
                    <div>
                        <label class="form-label" data-lang="first_name">الاسم الأول</label>
                        <div class="input-group">
                            <i class="fas fa-user input-icon"></i>
                            <input type="text" name="firstName" class="form-control"
                                   data-lang-placeholder="first_name" placeholder="الاسم الأول" required />
                        </div>
                    </div>
                    <div>
                        <label class="form-label" data-lang="last_name">الاسم الأخير</label>
                        <div class="input-group">
                            <i class="fas fa-user input-icon"></i>
                            <input type="text" name="lastName" class="form-control"
                                   data-lang-placeholder="last_name" placeholder="الاسم الأخير" required />
                        </div>
                    </div>
                </div>

                <!-- Email -->
                <div>
                    <label class="form-label" data-lang="email">البريد الإلكتروني</label>
                    <div class="input-group">
                        <i class="fas fa-envelope input-icon"></i>
                        <input type="email" name="email" class="form-control"
                               placeholder="example@email.com" required />
                    </div>
                </div>

                <!-- Row 2: Phone + SSN -->
                <div class="form-row-2">
                    <div>
                        <label class="form-label" data-lang="phone_number">رقم الهاتف</label>
                        <div class="input-group">
                            <i class="fas fa-phone input-icon"></i>
                            <input type="tel" name="phoneNum" class="form-control"
                                   placeholder="01xxxxxxxxx" />
                        </div>
                    </div>
                    <div>
                        <label class="form-label" data-lang="ssn">الرقم القومي</label>
                        <div class="input-group">
                            <i class="fas fa-id-card input-icon"></i>
                            <input type="text" name="ssn" class="form-control"
                                   data-lang-placeholder="ssn" placeholder="الرقم القومي" required />
                        </div>
                    </div>
                </div>

                <!-- Row 3: Gender + Specialization + Role -->
                <div class="form-row-2">
                    <div>
                        <label class="form-label" data-lang="gender">الجنس</label>
                        <div class="input-group">
                            <i class="fas fa-venus-mars input-icon"></i>
                            <select name="gender" class="form-control" required>
                                <option value="" data-lang="select">-- اختر --</option>
                                @foreach (var g in Enum.GetValues(typeof(Gender)))
                                {
                                    <option value="@g" data-en="@g" data-ar="@(g.ToString() == "Male" ? "ذكر" : "أنثى")">
                                        @(g.ToString() == "Male" ? "ذكر" : "أنثى")
                                    </option>
                                }
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="form-label" data-lang="specialization">التخصص</label>
                        <div class="input-group">
                            <i class="fas fa-hard-hat input-icon"></i>
                            <select name="specialization" class="form-control" required>
                                <option value="" data-lang="select">-- اختر --</option>
                                @foreach (var s in Enum.GetValues(typeof(Specialization)))
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div>
                        <label class="form-label">
                            <span data-lang="role">الدور الوظيفي</span>
                        </label>
                        <div class="input-group">
                            <i class="fas fa-briefcase input-icon"></i>
                            <select name="role" class="form-control" required>
                                <option value="" data-lang="select_role_option">-- اختر الدور --</option>
                                <option value="Engineer" data-lang="role_engineer">مهندس</option>
                                <option value="ProjectManager" data-lang="role_pm">مدير مشروع</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Salary -->
                <div>
                    <label class="form-label" data-lang="salary">الراتب</label>
                    <div class="input-group">
                        <i class="fas fa-money-bill input-icon"></i>
                        <input type="number" name="salary" class="form-control"
                               placeholder="0.00" min="0" step="any" required />
                    </div>
                </div>

                <!-- Password -->
                <div>
                    <label class="form-label" data-lang="login_password">كلمة المرور</label>
                    <div class="input-group">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" name="password" class="form-control"
                               data-lang-placeholder="login_password_placeholder" placeholder="أدخل كلمة المرور" required />
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-user-plus"></i>
                    <span data-lang="create_account">إنشاء الحساب</span>
                </button>
            </form>

            <div class="switch-link">
                <span data-lang="already_have_account">لديك حساب بالفعل؟</span>
                <a asp-action="Login" asp-controller="Account" data-lang="login_submit">تسجيل الدخول</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/translations.js"></script>
    <script src="~/js/lang-switch.js"></script>
    <script src="~/js/auth-theme.js"></script>
</body>
</html>