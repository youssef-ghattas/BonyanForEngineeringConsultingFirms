@using Bonyan.DAL.Enums
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>إنشاء حساب - بنيان</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap"
          rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background: #F4F6F9;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px 15px;
        }

        .register-wrapper {
            display: flex;
            width: 980px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        }

        /* ── Left Panel ───────────────────────────── */
        .register-left {
            width: 35%;
            background: linear-gradient(160deg, #1B3A6B 0%, #112240 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 30px;
            text-align: center;
        }

        .logo-icon {
            width: 80px;
            height: 80px;
            background: rgba(200,146,42,0.2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
        }

            .logo-icon i {
                font-size: 2.5rem;
                color: #C8922A;
            }

        .register-left h1 {
            color: #fff;
            font-size: 1.9rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .divider {
            width: 50px;
            height: 3px;
            background: #C8922A;
            border-radius: 3px;
            margin: 15px auto;
        }

        .register-left p {
            color: rgba(255,255,255,0.7);
            font-size: 0.9rem;
            line-height: 1.8;
        }

        .steps-list {
            margin-top: 30px;
            text-align: right;
            list-style: none;
            width: 100%;
        }

            .steps-list li {
                color: rgba(255,255,255,0.8);
                font-size: 0.85rem;
                padding: 8px 0;
                display: flex;
                align-items: center;
                gap: 10px;
                border-bottom: 1px solid rgba(255,255,255,0.08);
            }

                .steps-list li i {
                    color: #C8922A;
                    width: 18px;
                }

        /* ── Right Panel ──────────────────────────── */
        .register-right {
            width: 65%;
            background: #fff;
            padding: 40px;
            overflow-y: auto;
        }

            .register-right h2 {
                color: #1B3A6B;
                font-size: 1.5rem;
                font-weight: 700;
                margin-bottom: 5px;
            }

            .register-right > p {
                color: #888;
                font-size: 0.88rem;
                margin-bottom: 25px;
            }

        .section-title {
            font-size: 0.82rem;
            font-weight: 700;
            color: #C8922A;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 20px 0 12px;
            padding-bottom: 6px;
            border-bottom: 2px solid #FFF3CD;
        }

        .form-label {
            font-weight: 600;
            color: #1B3A6B;
            font-size: 0.88rem;
            margin-bottom: 5px;
        }

        .input-wrap {
            position: relative;
        }

            .input-wrap .icon {
                position: absolute;
                right: 13px;
                top: 50%;
                transform: translateY(-50%);
                color: #1B3A6B;
                font-size: 0.85rem;
                z-index: 5;
            }

        .form-control, .form-select {
            border: 1.5px solid #E0E0E0;
            border-radius: 9px;
            padding: 10px 38px 10px 12px;
            font-family: 'Cairo', sans-serif;
            font-size: 0.88rem;
            transition: all 0.3s;
            width: 100%;
        }

        .form-select {
            padding-right: 38px;
        }

            .form-control:focus, .form-select:focus {
                border-color: #1B3A6B;
                box-shadow: 0 0 0 3px rgba(27,58,107,0.1);
                outline: none;
            }

        .btn-register {
            width: 100%;
            background: linear-gradient(135deg, #1B3A6B, #2a5298);
            color: #fff;
            border: none;
            padding: 13px;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Cairo', sans-serif;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(27,58,107,0.3);
            }

        .login-link {
            text-align: center;
            margin-top: 15px;
            font-size: 0.88rem;
            color: #666;
        }

            .login-link a {
                color: #1B3A6B;
                font-weight: 700;
                text-decoration: none;
            }

                .login-link a:hover {
                    text-decoration: underline;
                }

        .alert-error {
            background: #FFF0F0;
            border: 1px solid #FFCCCC;
            border-radius: 10px;
            padding: 11px 15px;
            color: #DC3545;
            font-size: 0.87rem;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        @@media (max-width: 768px) {
            .register-wrapper {
                flex-direction: column;
                width: 95%;
            }

            .register-left, .register-right {
                width: 100%;
            }

            .register-left {
                padding: 30px 20px;
            }
        }
    </style>
</head>
<body>
    <div class="register-wrapper">

        <!-- ── Left Panel ─────────────────────────────── -->
        <div class="register-left">
            <div class="logo-icon"><i class="fas fa-building"></i></div>
            <h1>بنيان</h1>
            <div class="divider"></div>
            <p>منصة متكاملة لإدارة شركات الاستشارات الهندسية</p>
            <ul class="steps-list">
                <li><i class="fas fa-check-circle"></i> إدارة المشاريع والمهام</li>
                <li><i class="fas fa-check-circle"></i> رفع المستندات والرسومات</li>
                <li><i class="fas fa-check-circle"></i> متابعة المواد والمخزون</li>
                <li><i class="fas fa-check-circle"></i> الفواتير والمدفوعات</li>
                <li><i class="fas fa-check-circle"></i> زيارات الموقع والتقارير</li>
            </ul>
        </div>

        <!-- ── Right Panel ────────────────────────────── -->
        <div class="register-right">
            <h2>إنشاء حساب جديد</h2>
            <p>أدخل بياناتك لإنشاء حسابك في المنصة</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-action="Register" asp-controller="Account">
                @Html.AntiForgeryToken()

                <!-- Personal Info -->
                <div class="section-title"><i class="fas fa-user me-1"></i> البيانات الشخصية</div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">الاسم الأول *</label>
                        <div class="input-wrap">
                            <i class="fas fa-user icon"></i>
                            <input type="text" name="FirstName" class="form-control"
                                   placeholder="الاسم الأول" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">الاسم الأخير *</label>
                        <div class="input-wrap">
                            <i class="fas fa-user icon"></i>
                            <input type="text" name="LastName" class="form-control"
                                   placeholder="الاسم الأخير" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">البريد الإلكتروني *</label>
                        <div class="input-wrap">
                            <i class="fas fa-envelope icon"></i>
                            <input type="email" name="Email" class="form-control"
                                   placeholder="example@email.com" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">رقم الهاتف</label>
                        <div class="input-wrap">
                            <i class="fas fa-phone icon"></i>
                            <input type="text" name="PhoneNum" class="form-control"
                                   placeholder="05xxxxxxxx" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">رقم الهوية (SSN) *</label>
                        <div class="input-wrap">
                            <i class="fas fa-id-card icon"></i>
                            <input type="text" name="SSN" class="form-control"
                                   placeholder="رقم الهوية الوطنية" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">تاريخ التعيين *</label>
                        <div class="input-wrap">
                            <i class="fas fa-calendar icon"></i>
                            <input type="date" name="HireDate" class="form-control" required
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">الجنس *</label>
                        <div class="input-wrap">
                            <i class="fas fa-venus-mars icon"></i>
                            <select name="Gender" class="form-select" required>
                                <option value="">-- اختر --</option>
                                @foreach (var g in Enum.GetValues(typeof(Gender)))
                                {
                                    <option value="@g">@g</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">التخصص *</label>
                        <div class="input-wrap">
                            <i class="fas fa-hard-hat icon"></i>
                            <select name="Specialization" class="form-select" required>
                                <option value="">-- اختر --</option>
                                @foreach (var s in Enum.GetValues(typeof(Specialization)))
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">الراتب *</label>
                        <div class="input-wrap">
                            <i class="fas fa-money-bill icon"></i>
                            <input type="number" name="Salary" class="form-control"
                                   placeholder="0.00" step="any" min="0" required />
                        </div>
                    </div>
                </div>

                <!-- Account Info -->
                <div class="section-title"><i class="fas fa-lock me-1"></i> بيانات الحساب</div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">اسم المستخدم *</label>
                        <div class="input-wrap">
                            <i class="fas fa-at icon"></i>
                            <input type="text" name="username" class="form-control"
                                   placeholder="اسم المستخدم" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">كلمة المرور *</label>
                        <div class="input-wrap">
                            <i class="fas fa-lock icon"></i>
                            <input type="password" name="password" class="form-control"
                                   placeholder="كلمة المرور" required />
                        </div>
                    </div>
                </div>

                <a asp-controller="Account" asp-action="Login" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i>
                    انشاء حساب
                </a>
                <div class="login-link">
                    لديك حساب بالفعل؟
                    <a asp-controller="Account" asp-action="Login">تسجيل الدخول</a>
                </div>
                <div style="text-align:center; margin-top:15px; font-size:0.88rem; color:#666;">
                    ليس لديك حساب؟
                    <a asp-controller="Account" asp-action="Register"
                       style="color:#1B3A6B; font-weight:700; text-decoration:none;">
                        إنشاء حساب جديد
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>